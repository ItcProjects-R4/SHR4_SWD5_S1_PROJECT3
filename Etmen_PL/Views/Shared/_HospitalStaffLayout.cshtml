@inject Etmen_DAL.Repositories.Interfaces.IUnitOfWork Uow
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@{
    Layout = null;

    string dashboardUrl = "/";
    int? providerId = null;
    string providerName = "";
    string providerAddress = "";
    int availableBeds = 0;

    if (User?.Identity?.IsAuthenticated == true)
    {
        if (User.IsInRole("Doctor"))
        {
            dashboardUrl = "/DoctorDashboard";
        }
        else if (User.IsInRole("Admin") || User.IsInRole("CrisisAdmin"))
        {
            dashboardUrl = "/AdminDashboard";
        }
        else if (User.IsInRole("HospitalStaff"))
        {
            dashboardUrl = "/HospitalQueue";

            var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (!string.IsNullOrEmpty(userId))
            {
                var staffProfile = Uow.StaffProfiles.Table
                    .Include(s => s.HealthcareProvider)
                    .FirstOrDefault(sp => sp.ApplicationUserId == userId);
                if (staffProfile != null && staffProfile.HealthcareProvider != null)
                {
                    providerId = staffProfile.HealthcareProviderId;
                    providerName = staffProfile.HealthcareProvider.Name;
                    providerAddress = staffProfile.HealthcareProvider.Address ?? "";
                    availableBeds = staffProfile.HealthcareProvider.AvailableBeds ?? 0;
                }
            }
        }
        else
        {
            dashboardUrl = "/PatientDashboard";
        }
    }
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — إطمن مستشفى</title>
    
    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            --primary: #1A6FBF;
            --primary-dark: #0D4C8A;
            --primary-light: #E8F4FD;
            --accent: #3cd5cb;
            --success: #27AE60;
            --danger: #E74C3C;
            --warning: #F39C12;
            --bg: #F4F7F9;
            --card-border: #E2E8F0;
            --text-dark: #2C3E50;
            --text-muted: #7F8C8D;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background-color: var(--bg);
            color: var(--text-dark);
            min-height: 100vh;
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
        }

        /* Top Header Navbar */
        .hospital-navbar {
            background: #FFFFFF;
            border-bottom: 1px solid var(--card-border);
            box-shadow: 0 4px 25px rgba(0, 0, 0, 0.02);
            padding: 0.8rem 2rem;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            transition: transform 0.2s;
        }
        .brand-logo:hover {
            transform: scale(1.02);
        }
        .logo-box {
            width: 40px; height: 40px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 1.2rem;
            box-shadow: 0 4px 12px rgba(26, 111, 191, 0.25);
        }
        .logo-text {
            font-size: 1.4rem; font-weight: 900; color: var(--text-dark);
            line-height: 1;
        }
        .logo-text span {
            color: var(--primary);
        }
        .logo-subtitle {
            font-size: 0.65rem; color: var(--text-muted);
            font-weight: 500; letter-spacing: 1px;
            display: block; margin-top: 2px;
        }

        /* Nav links */
        .hospital-nav-menu {
            display: flex;
            align-items: center;
            gap: 8px;
            margin: 0; padding: 0;
            list-style: none;
        }
        .hospital-nav-link {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 700;
            font-size: 0.9rem;
            padding: 8px 16px;
            border-radius: 12px;
            transition: all 0.3s;
            display: flex; align-items: center; gap: 8px;
        }
        .hospital-nav-link:hover {
            color: var(--primary);
            background: var(--primary-light);
        }
        .hospital-nav-link.active {
            color: var(--primary);
            background: var(--primary-light);
            box-shadow: inset 0 0 0 1px rgba(26, 111, 191, 0.15);
        }

        .user-badge {
            background: var(--primary-light);
            border: 1px solid rgba(26, 111, 191, 0.1);
            color: var(--primary-dark);
            border-radius: 20px;
            padding: 5px 12px;
            font-size: 0.8rem;
            font-weight: 800;
            display: flex; align-items: center; gap: 8px;
        }

        /* Alerts */
        .alert-container {
            position: fixed;
            top: 90px;
            left: 20px;
            z-index: 9999;
            width: 320px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .custom-alert {
            background: white;
            border-radius: 14px;
            padding: 15px 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            border-right: 5px solid var(--primary);
            display: flex;
            align-items: flex-start;
            gap: 12px;
            font-size: 0.85rem;
            color: var(--text-dark);
        }
        .custom-alert-success { border-right-color: var(--success); }
        .custom-alert-danger { border-right-color: var(--danger); }
        .custom-alert-info { border-right-color: var(--primary); }

        .main-wrapper {
            flex: 1;
            padding: 2rem 0;
        }

        .hospital-footer {
            background: white;
            border-top: 1px solid var(--card-border);
            padding: 1.5rem 0;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.8rem;
            font-weight: 500;
        }

        /* ═══ RESPONSIVE — MOBILE FIXES ═══════════════════════════ */
        @@media (max-width: 991.98px) {
            .hospital-navbar {
                padding: 0.6rem 1rem;
            }
            .hospital-nav-menu {
                flex-direction: column;
                align-items: stretch;
                gap: 4px;
                width: 100%;
                margin-top: 0.75rem;
            }
            .hospital-nav-link {
                justify-content: flex-start;
                padding: 10px 14px;
                width: 100%;
            }
        }
        @@media (max-width: 767.98px) {
            .alert-container {
                top: 80px !important;
                left: 12px !important;
                right: 12px !important;
                width: auto !important;
            }
            .hospital-navbar {
                padding: 0.5rem 0.75rem;
            }
            .logo-text {
                font-size: 1.2rem;
            }
        }
        @@media (max-width: 575.98px) {
            .logo-subtitle {
                display: none;
            }
            .main-wrapper {
                padding: 1.5rem 0;
            }
        }
    </style>
</head>
<body>

    <!-- Top Navbar -->
    <nav class="hospital-navbar">
        <div class="container-fluid d-flex align-items-center justify-content-between flex-wrap gap-2">
            <a href="@dashboardUrl" class="brand-logo">
                <div class="logo-box">
                    <i class="fas fa-hospital-user"></i>
                </div>
                <div>
                    <span class="logo-text">إطمن <span>مستشفى</span></span>
                    <span class="logo-subtitle">بوابة إدارة الأسرة والفرز</span>
                </div>
            </a>

            <!-- Hamburger toggle for mobile -->
            <button class="btn btn-sm d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#hospitalNavbarContent"
                    aria-controls="hospitalNavbarContent" aria-expanded="false" aria-label="Toggle navigation"
                    style="background: var(--primary-light); color: var(--primary); border-radius: 8px; padding: 6px 10px;">
                <i class="fas fa-bars"></i>
            </button>

            <!-- Nav content -->
            <div class="collapse navbar-collapse w-100" id="hospitalNavbarContent">
                <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between w-100 gap-3 mt-2 mt-lg-0">
                    <ul class="hospital-nav-menu">
                        <li>
                            <a href="/HospitalQueue" class="hospital-nav-link @(Context.Request.Path.Value?.Equals("/HospitalQueue", StringComparison.OrdinalIgnoreCase) == true ? "active" : "")">
                                <i class="fas fa-list-ol"></i> قائمة الانتظار والفرز
                            </a>
                        </li>
                        @if (providerId.HasValue)
                        {
                            <li>
                                <a href="#" class="hospital-nav-link text-warning fw-bold" data-bs-toggle="modal" data-bs-target="#updateCapacityNavbarModal">
                                    <i class="fas fa-bed"></i> القدرة الاستيعابية (@availableBeds)
                                </a>
                            </li>
                            <li>
                                <a href="#" class="hospital-nav-link text-danger fw-bold" data-bs-toggle="modal" data-bs-target="#requestSupportNavbarModal">
                                    <i class="fas fa-triangle-exclamation animate__animated animate__pulse animate__infinite"></i> طلب دعم طبي عاجل
                                </a>
                            </li>
                        }
                        <li>
                            <a href="/HospitalQueue/Profile" class="hospital-nav-link @(Context.Request.Path.Value?.Contains("Profile") == true ? "active" : "")">
                                <i class="fas fa-user-gear text-primary"></i> الملف الشخصي
                            </a>
                        </li>
                        <li>
                            <a href="/AdminCrisis/Heatmap" class="hospital-nav-link" target="_blank">
                                <i class="fas fa-biohazard text-danger"></i> خريطة تفشي الأوبئة
                            </a>
                        </li>
                        <li>
                            <a href="/AdminDashboard/NormalMap" class="hospital-nav-link" target="_blank">
                                <i class="fas fa-map-location-dot text-primary"></i> خريطة الموارد والمراكز
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        <div class="user-badge">
                            <i class="fas fa-clinic-medical"></i> طاقم طبي
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            <button type="submit" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                                <i class="fas fa-sign-out-alt"></i> خروج
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Floating Alerts -->
    <div class="alert-container">
        @if (TempData["Success"] != null)
        {
            <div class="custom-alert custom-alert-success animate__animated animate__fadeInLeft" role="alert">
                <i class="fas fa-check-circle text-success fs-5"></i>
                <div>@TempData["Success"]</div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="custom-alert custom-alert-danger animate__animated animate__fadeInLeft" role="alert">
                <i class="fas fa-exclamation-circle text-danger fs-5"></i>
                <div>@TempData["Error"]</div>
            </div>
        }
    </div>

    <!-- Main Content Wrapper -->
    <div class="main-wrapper">
        <main class="container-fluid px-4">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="hospital-footer">
        <span>© @DateTime.Now.Year — منصة إطمن للخدمات الطبية | بوابة الطاقم الطبي للمستشفيات</span>
    </footer>

    @if (User?.IsInRole("HospitalStaff") == true && providerId.HasValue)
    {
        <!-- ═══════════════════════════════════════
             Modal: Update Beds Capacity
        ═══════════════════════════════════════ -->
        <div class="modal fade" id="updateCapacityNavbarModal" tabindex="-1" aria-labelledby="updateCapacityNavbarLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius:20px;">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold" id="updateCapacityNavbarLabel">
                            <i class="fas fa-bed text-warning me-2"></i> تحديث القدرة الاستيعابية
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-controller="HospitalQueue" asp-action="UpdateProfile" method="post">
                        <div class="modal-body px-4 py-3">
                            <input type="hidden" name="ProviderId" value="@providerId" />
                            <input type="hidden" name="ProviderName" value="@providerName" />
                            <input type="hidden" name="ProviderAddress" value="@providerAddress" />
                            <p class="text-muted small mb-3">المستشفى: <strong>@providerName</strong></p>
                            <label class="form-label fw-bold small">عدد الأسرة الشاغرة الحالية</label>
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <input type="range" class="form-range flex-grow-1" id="navBedRange"
                                       name="AvailableBeds" min="0" max="150" value="@availableBeds"
                                       oninput="document.getElementById('navBedVal').textContent = this.value" />
                                <span class="badge bg-primary fs-6 px-3 py-2" id="navBedVal">@availableBeds</span>
                            </div>
                            <div class="text-muted small">
                                <i class="fas fa-info-circle me-1"></i>
                                هذا التحديث سيعكس فوراً على خريطة الموارد الطبية.
                            </div>
                        </div>
                        <div class="modal-footer border-0 pt-0">
                            <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">إلغاء</button>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">
                                <i class="fas fa-save me-1"></i> حفظ التحديث
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════
             Modal: Request Admin Medical Support
        ═══════════════════════════════════════ -->
        <div class="modal fade" id="requestSupportNavbarModal" tabindex="-1" aria-labelledby="requestSupportNavbarLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius:20px;">
                    <div class="modal-header border-0 pb-0" style="background:linear-gradient(135deg,#fff1f1,#fff);">
                        <h5 class="modal-title fw-bold text-danger" id="requestSupportNavbarLabel">
                            <i class="fas fa-triangle-exclamation me-2"></i> طلب دعم طبي عاجل
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body px-4 py-3">
                        <div class="alert alert-warning rounded-3 mb-3" style="font-size:.9rem;">
                            <i class="fas fa-siren me-1"></i>
                            سيتم إرسال تنبيه عاجل فوري إلى الإدارة المركزية لطلب تعزيزات وإمدادات طبية لـ <strong>@providerName</strong>.
                        </div>
                        <p class="text-muted small">استخدم هذا الخيار فقط في حالات النقص الحاد في الأسرة أو الكوادر أو الإمدادات.</p>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">إلغاء</button>
                        <form asp-controller="HospitalQueue" asp-action="RequestSupport" method="post" class="m-0">
                            <input type="hidden" name="ProviderId" value="@providerId" />
                            <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">
                                <i class="fas fa-paper-plane me-1"></i> إرسال طلب الدعم الآن
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
