@model Etmen_PL.Models.ViewModels.Hospital.StaffPersonalProfileViewModel
@{
    ViewData["Title"] = "الملف الشخصي للطاقم الطبي";
    Layout = "~/Views/Shared/_HospitalStaffLayout.cshtml";
}

<style>
    .profile-card {
        background: #FFFFFF;
        border: 1px solid var(--card-border);
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        padding: 30px;
        margin-bottom: 24px;
    }
    .profile-header {
        border-bottom: 1px solid var(--card-border);
        padding-bottom: 20px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 15px;
    }
    .profile-avatar {
        width: 60px;
        height: 60px;
        background: var(--primary-light);
        color: var(--primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="profile-card animate__animated animate__fadeIn">
                <div class="profile-header">
                    <div class="profile-avatar">
                        <i class="fas fa-user-gear"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-1">تعديل البيانات الشخصية</h4>
                        <p class="text-muted small mb-0">@Model.HospitalName | دور العمل: @Model.RoleType | الوردية: @Model.ActiveShift</p>
                    </div>
                </div>

                <form asp-controller="HospitalQueue" asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <h5 class="fw-bold mb-3 text-primary"><i class="fas fa-id-card me-1"></i> المعلومات الأساسية</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="FirstName" class="form-control" placeholder="الاسم الأول" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="LastName" class="form-control" placeholder="اسم العائلة" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="Email" class="form-control" placeholder="البريد الإلكتروني" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="رقم الهاتف" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="fw-bold mb-3 text-primary"><i class="fas fa-key me-1"></i> تغيير كلمة المرور (اختياري)</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <label asp-for="CurrentPassword" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="CurrentPassword" class="form-control" placeholder="أدخل كلمة المرور الحالية" />
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewPassword" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="NewPassword" class="form-control" placeholder="أدخل كلمة المرور الجديدة" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmNewPassword" class="form-label small fw-bold text-muted"></label>
                            <input asp-for="ConfirmNewPassword" class="form-control" placeholder="تأكيد كلمة المرور الجديدة" />
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 fw-bold">
                            <i class="fas fa-save me-1"></i> حفظ التغييرات
                        </button>
                        <a href="/HospitalQueue" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold">
                            إلغاء
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
