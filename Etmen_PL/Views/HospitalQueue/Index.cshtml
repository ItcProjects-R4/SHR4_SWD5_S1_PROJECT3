@section Scripts {
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function updateBedLabel(val) {
            document.getElementById('bedVal').innerText = val;
            
            // Proactively update bed status chart values if exists
            if (window.bedChart) {
                const totalBeds = 150; // Mock Max Beds Capacity
                const available = parseInt(val);
                const occupied = Math.max(0, totalBeds - available);
                window.bedChart.data.datasets[0].data = [available, occupied];
                window.bedChart.update();
            }
        }

        // Web Audio API medical warning synthesizer
        function playMedicalAlertSound() {
            try {
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                
                function beep(freq, duration, delay) {
                    setTimeout(() => {
                        const osc = audioCtx.createOscillator();
                        const gain = audioCtx.createGain();
                        osc.connect(gain);
                        gain.connect(audioCtx.destination);
                        osc.frequency.value = freq;
                        osc.type = 'sine';
                        gain.gain.setValueAtTime(0.25, audioCtx.currentTime);
                        gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + duration);
                        osc.start();
                        osc.stop(audioCtx.currentTime + duration);
                    }, delay);
                }
                
                beep(880, 0.15, 0);
                beep(880, 0.15, 200);
            } catch (e) {
                console.error("Audio Context initialization failed: ", e);
            }
        }

        // Haversine Distance Calculator (km)
        function getHaversineDistance(lat1, lon1, lat2, lon2) {
            const R = 6371; // Radius of the earth in km
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = 
                Math.sin(dLat/2) * Math.sin(dLat/2) +
                Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * 
                Math.sin(dLon/2) * Math.sin(dLon/2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
            return R * c; // Distance in km
        }

        $(document).ready(function() {
            // 1. Bed Status Chart Configuration
            const ctxBed = document.getElementById('bedStatusChart').getContext('2d');
            const availBeds = parseInt('@(Model.AvailableBeds ?? 0)');
            const totalMaxBeds = 150;
            const occupiedBeds = Math.max(0, totalMaxBeds - availBeds);

            window.bedChart = new Chart(ctxBed, {
                type: 'doughnut',
                data: {
                    labels: ['الأسرة الشاغرة', 'الأسرة المشغولة'],
                    datasets: [{
                        data: [availBeds, occupiedBeds],
                        backgroundColor: ['#1A6FBF', '#E2E8F0'],
                        borderWidth: 2,
                        borderColor: '#ffffff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                font: {
                                    family: 'Tajawal',
                                    size: 11,
                                    weight: 'bold'
                                }
                            }
                        },
                        title: {
                            display: true,
                            text: 'سعة الأسرة والاشغال المتاحة',
                            font: {
                                family: 'Tajawal',
                                size: 14,
                                weight: '900'
                            }
                        }
                    },
                    cutout: '65%'
                }
            });

            // 2. Case Priority distribution chart
            const ctxPriority = document.getElementById('priorityChart').getContext('2d');
            window.priorityChartObj = new Chart(ctxPriority, {
                type: 'bar',
                data: {
                    labels: ['حرجة جداً', 'متوسطة الخطورة', 'مستقرة'],
                    datasets: [{
                        label: 'عدد الحالات',
                        data: [parseInt('@criticalCount'), parseInt('@mediumCount'), parseInt('@lowCount')],
                        backgroundColor: ['#E74C3C', '#F39C12', '#27AE60'],
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        title: {
                            display: true,
                            text: 'تصنيف الحالات المتواجدة حسب درجة الخطورة',
                            font: {
                                family: 'Tajawal',
                                size: 14,
                                weight: '900'
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1
                            }
                        },
                        x: {
                            ticks: {
                                font: {
                                    family: 'Tajawal',
                                    weight: 'bold'
                                }
                            }
                        }
                    }
                }
            });

            // 3. Dynamic Haversine ETA calculations for all table cells
            const hospLat = parseFloat('@Model.ProviderLatitude');
            const hospLng = parseFloat('@Model.ProviderLongitude');

            if (!isNaN(hospLat) && !isNaN(hospLng)) {
                $('.eta-calc-cell').each(function() {
                    const lat = parseFloat($(this).attr('data-lat'));
                    const lng = parseFloat($(this).attr('data-lng'));

                    if (!isNaN(lat) && !isNaN(lng) && lat !== 0 && lng !== 0) {
                        const dist = getHaversineDistance(hospLat, hospLng, lat, lng);
                        const eta = Math.round((dist / 50) * 60 + 2); // 50 km/h avg speed + 2 min overhead
                        $(this).html(`<i class="fas fa-truck-medical text-danger"></i> ${dist.toFixed(1)} كم (${eta} دقيقة)`);
                    } else {
                        $(this).html('<span class="text-muted small">غير متوفر</span>');
                    }
                });
            } else {
                $('.eta-calc-cell').html('<span class="text-muted small">غير متوفر</span>');
            }

            // 4. SignalR Real-Time connection for incoming pending requests
            const providerId = '@Model.ProviderId';
            
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/queue")
                .withAutomaticReconnect()
                .build();

            connection.on("NewEmergencyRequest", function(request) {
                // New case received! Play alarm and show toast
                playMedicalAlertSound();
                const toastEl = document.getElementById('newAmbulanceToast');
                if (toastEl) {
                    const toast = new bootstrap.Toast(toastEl);
                    toast.show();
                }
                
                // Reload view after 3 seconds to show new rows in the table
                setTimeout(function() {
                    location.reload();
                }, 3000);
            });

            connection.start().then(function() {
                console.log("SignalR connected to QueueHub.");
                if (providerId) {
                    connection.invoke("JoinProviderGroup", providerId).then(function() {
                        console.log("Joined provider group: " + providerId);
                    }).catch(function(err) {
                        console.error(err);
                    });
                }
            }).catch(function(err) {
                console.error("SignalR Connection Error: ", err);
            });
        });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
    // ══════════════════════════════════════════════════════
    //  HOSPITAL AMBULANCE LIVE DISPATCH MAP
    // ══════════════════════════════════════════════════════
    (function() {
        const HOSP_LAT   = parseFloat('@Model.ProviderLatitude') || 30.0444;
        const HOSP_LNG   = parseFloat('@Model.ProviderLongitude') || 31.2357;
        const TOTAL_AMBS = 4;   // simulated total ambulances for this hospital
        const AVG_KMH    = 40;
        const ANIM_FPS   = 15;
        const SPEEDUP    = 12;  // 12× real-time

        // Accepted cases (patients that ambulances are heading to)
        const acceptedCases = [
            @foreach (var item in acceptedItems)
            {
                if (item.Latitude.HasValue && item.Longitude.HasValue)
                {
                    @:{ id: @item.RequestId, name: '@item.PatientName.Replace("'","\\'")', lat: @item.Latitude, lng: @item.Longitude, type: '@item.EmergencyType.Replace("'","\\'")', waited: @item.WaitingMinutes },
                }
            }
        ];

        // ── Haversine ──
        function haversineKm(lat1, lng1, lat2, lng2) {
            const R = 6371, dLat=(lat2-lat1)*Math.PI/180, dLng=(lng2-lng1)*Math.PI/180;
            const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLng/2)**2;
            return R*2*Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        }

        // ── Init Leaflet map ──
        const dispMap = L.map('hospAmbMap').setView([HOSP_LAT, HOSP_LNG], 12);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',
            {attribution:'&copy; OpenStreetMap'}).addTo(dispMap);

        // Hospital marker
        L.marker([HOSP_LAT, HOSP_LNG], {
            icon: L.divIcon({
                className:'',
                html:'<div style="font-size:22px;filter:drop-shadow(0 2px 4px rgba(0,0,0,.3))">🏥</div>',
                iconSize:[28,28], iconAnchor:[14,14]
            })
        }).addTo(dispMap).bindPopup('<b>@Html.Raw(Model.ProviderName?.Replace("'", "\\'") ?? "")</b>');

        // ── Capacity calculation ──
        const usedAmbs  = Math.min(acceptedCases.length, TOTAL_AMBS);
        const freeAmbs  = TOTAL_AMBS - usedAmbs;
        const capPct    = Math.max(0, Math.round(freeAmbs / TOTAL_AMBS * 100));

        document.getElementById('capLabel').textContent = `${freeAmbs}/${TOTAL_AMBS} متاح`;
        const capBar = document.getElementById('capBar');
        capBar.style.width   = capPct + '%';
        capBar.style.background = capPct === 0 ? '#ef4444' : capPct < 50 ? '#f59e0b' : '#22c55e';

        // Show no-ambulance alert if all busy
        if (freeAmbs <= 0) {
            document.getElementById('noAmbHospAlert').style.display = 'block';
            // Find nearest hospital hint from static data (just a message here)
            document.getElementById('altHospText').textContent =
                'أنصح بتحويل الحالات الجديدة لأقرب مستشفى مجاور حتى تعود إحدى السيارات.';
        }

        // ── Draw patient markers + animated ambulances ──
        let dispHtml = '';

        acceptedCases.forEach((c, idx) => {
            if (!c.lat || !c.lng) return;

            const dist      = haversineKm(HOSP_LAT, HOSP_LNG, c.lat, c.lng);
            const etaMin    = Math.round((dist / AVG_KMH) * 60);
            const simMs     = (etaMin * 60000) / SPEEDUP;
            const stepMs    = 1000 / ANIM_FPS;
            const steps     = Math.ceil(simMs / stepMs);

            // Patient marker (red circle)
            L.marker([c.lat, c.lng], {
                icon: L.divIcon({
                    className:'',
                    html:`<div style="background:#ef4444;width:14px;height:14px;border:2px solid #fff;border-radius:50%;box-shadow:0 0 8px #ef4444;"></div>`,
                    iconSize:[14,14], iconAnchor:[7,7]
                })
            }).addTo(dispMap).bindPopup(`<b>${c.name}</b><br>${c.type}`);

            // Route line (dashed)
            L.polyline([[HOSP_LAT, HOSP_LNG],[c.lat, c.lng]], {
                color:'#ef4444', dashArray:'6 4', weight:2, opacity:.55
            }).addTo(dispMap);

            // Ambulance marker (starts at hospital)
            const ambM = L.marker([HOSP_LAT, HOSP_LNG], {
                icon: L.divIcon({
                    className:'',
                    html:`<div style="font-size:20px;animation:bounce 1s infinite ${idx*0.3}s;">🚑</div>`,
                    iconSize:[26,26], iconAnchor:[13,13]
                }),
                zIndexOffset: 900 + idx
            }).addTo(dispMap).bindPopup(`إسعاف → ${c.name}`);

            // Animate from hospital to patient (with state persistence)
            const startTimeKey = "amb_start_" + c.id;
            let startTimeStr = localStorage.getItem(startTimeKey);
            if (!startTimeStr) {
                startTimeStr = Date.now().toString();
                localStorage.setItem(startTimeKey, startTimeStr);
            }
            const startTime = parseInt(startTimeStr);
            const elapsed = Date.now() - startTime;

            const startReturnJourney = (initialRStep) => {
                let rStep = initialRStep;
                const retTimer = setInterval(() => {
                    rStep = Math.min(rStep + 1, steps);
                    const rt = rStep / steps;
                    const re = rt < .5 ? 2*rt*rt : -1+(4-2*rt)*rt;
                    ambM.setLatLng([c.lat + (HOSP_LAT - c.lat) * re, c.lng + (HOSP_LNG - c.lng) * re]);
                    if (rStep >= steps) {
                        clearInterval(retTimer);
                        localStorage.removeItem(startTimeKey);
                    }
                }, stepMs);
            };

            if (elapsed < simMs) {
                let step = Math.floor(elapsed / stepMs);
                const timer = setInterval(() => {
                    step = Math.min(step + 1, steps);
                    const t    = step / steps;
                    const ease = t < .5 ? 2*t*t : -1+(4-2*t)*t;
                    const lat  = HOSP_LAT + (c.lat - HOSP_LAT) * ease;
                    const lng  = HOSP_LNG + (c.lng - HOSP_LNG) * ease;
                    ambM.setLatLng([lat, lng]);
                    if (step >= steps) {
                        clearInterval(timer);
                        setTimeout(() => {
                            startReturnJourney(0);
                        }, 3000);
                    }
                }, stepMs);
            } else if (elapsed < simMs + 3000) {
                ambM.setLatLng([c.lat, c.lng]);
                const remainingWait = (simMs + 3000) - elapsed;
                setTimeout(() => {
                    startReturnJourney(0);
                }, remainingWait);
            } else if (elapsed < 2 * simMs + 3000) {
                const elapsedReturn = elapsed - (simMs + 3000);
                let initialRStep = Math.floor(elapsedReturn / stepMs);
                const rt = Math.min(initialRStep / steps, 1);
                const re = rt < .5 ? 2*rt*rt : -1+(4-2*rt)*rt;
                ambM.setLatLng([c.lat + (HOSP_LAT - c.lat) * re, c.lng + (HOSP_LNG - c.lng) * re]);
                
                startReturnJourney(initialRStep);
            } else {
                ambM.setLatLng([HOSP_LAT, HOSP_LNG]);
                localStorage.removeItem(startTimeKey);
            }

            // Dispatch list row
            dispHtml += `
                <div class="d-flex align-items-center gap-2 p-2 mb-1 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0;font-size:.78rem;">
                    <span>🚑</span>
                    <div class="flex-grow-1 fw-700">${c.name}
                        <span class="text-muted fw-600"> — ${c.type}</span>
                    </div>
                    <span class="badge bg-warning text-dark rounded-pill" style="font-size:.68rem;">${dist.toFixed(1)} كم · ${etaMin} د</span>
                </div>`;
        });

        if (acceptedCases.length === 0) {
            dispHtml = `<div class="text-center text-muted py-3 small">
                <i class="fas fa-check-circle text-success fs-4 mb-1"></i><br>
                لا توجد سيارات إسعاف متحركة حالياً — جميع السيارات في المستشفى
            </div>`;
            // Show available ambulance markers at hospital
            for (let i = 0; i < TOTAL_AMBS; i++) {
                const offsetLat = HOSP_LAT + (Math.random() - 0.5) * 0.005;
                const offsetLng = HOSP_LNG + (Math.random() - 0.5) * 0.005;
                L.marker([offsetLat, offsetLng], {
                    icon: L.divIcon({
                        className:'',
                        html:`<div style="background:#22c55e;width:12px;height:12px;border:2px solid #fff;border-radius:50%;box-shadow:0 0 6px #22c55e;"></div>`,
                        iconSize:[12,12], iconAnchor:[6,6]
                    })
                }).addTo(dispMap).bindPopup(`سيارة إسعاف #${(i+1).toString().padStart(2,'0')} — في المستشفى`);
            }
        }

        document.getElementById('dispatchList').innerHTML = dispHtml;
    })();
    </script>
}

