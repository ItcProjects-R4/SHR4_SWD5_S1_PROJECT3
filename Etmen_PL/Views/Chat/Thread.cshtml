@using Etmen_PL.Models.ViewModels.Chat
@model ChatThreadViewModel
@{
    ViewData["Title"] = $"محادثة مع {Model.OtherUserName}";
    var isDoctor = User.IsInRole("Doctor");
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    Layout = isDoctor ? "~/Views/Shared/_DoctorLayout.cshtml" : "~/Views/Shared/_PatientLayout.cshtml";
}

<div class="chat-container" style="display:flex;flex-direction:column;height:calc(100vh - 200px);min-height:500px;">
    <!-- Chat Header -->
    <div class="dr-card mb-0 p-3" style="border-radius:18px 18px 0 0;flex-shrink:0;">
        <div class="d-flex align-items-center gap-3">
            <a href="/Chat/Index" class="btn btn-sm rounded-3" style="background:#F8FAFC;border:1px solid var(--border);color:var(--text);padding:6px 12px;">
                <i class="fas fa-arrow-right"></i>
            </a>
            <div class="sidebar-user-avatar flex-shrink-0" style="width:42px;height:42px;background:linear-gradient(135deg,var(--primary),var(--accent));">
                <i class="fas fa-user"></i>
            </div>
            <div>
                <h6 class="fw-bold mb-0">@Model.OtherUserName</h6>
                <small class="text-muted" id="chatStatus">محادثة خاصة</small>
            </div>
        </div>
    </div>

    <!-- Messages Area -->
    <div class="flex-grow-1 overflow-auto p-3" id="messagesArea" style="background:#F8FAFC;border-left:1px solid var(--border);border-right:1px solid var(--border);scroll-behavior:smooth;">
        @if (Model.Messages.Any())
        {
            foreach (var msg in Model.Messages)
            {
                var isMine = msg.SenderId == currentUserId;
                <div class="d-flex mb-3 @(isMine ? "justify-content-start" : "justify-content-end") message-item animate__animated animate__fadeInUp" style="animation-duration:0.3s;">
                    <div class="p-3 rounded-3" style="max-width:80%;background:@(isMine ? "var(--primary-light)" : "white");border:1px solid var(--border);border-radius:16px @(isMine ? "16px 4px 16px" : "4px 16px 16px");">
                        <p class="mb-1 small" style="line-height:1.5;">@msg.Message</p>
                        <div class="d-flex justify-content-between align-items-center gap-3">
                            <small class="text-muted" style="font-size:0.6rem;">@msg.SentAt.ToString("HH:mm")</small>
                            @if (isMine)
                            {
                                <small class="text-muted" style="font-size:0.6rem;">
                                    @if (msg.IsRead)
                                    {
                                        <i class="fas fa-check-double" style="color:var(--primary);"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-check"></i>
                                    }
                                </small>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="d-flex align-items-center justify-content-center h-100">
                <div class="text-center">
                    <div style="font-size:3rem;color:var(--border);margin-bottom:0.5rem;"><i class="far fa-comment-dots"></i></div>
                    <p class="text-muted small fw-bold mb-0">لا توجد رسائل بعد</p>
                    <p class="text-muted" style="font-size:0.75rem;">أرسل رسالة لبدء المحادثة</p>
                </div>
            </div>
        }
    </div>

    <!-- Typing Indicator -->
    <div id="typingIndicator" style="display:none;padding:4px 20px;background:white;border-left:1px solid var(--border);border-right:1px solid var(--border);">
        <div class="d-flex align-items-center gap-2" style="color:var(--text-muted);font-size:0.75rem;">
            <div class="typing-dots"><span>.</span><span>.</span><span>.</span></div>
            <span>@Model.OtherUserName يكتب...</span>
        </div>
    </div>

    <!-- Input Area -->
    <div class="p-3 dr-card" style="border-radius:0 0 18px 18px;flex-shrink:0;">
        <form id="chatForm" class="d-flex gap-2 align-items-end">
            @Html.AntiForgeryToken()
            <input type="hidden" id="receiverId" value="@Model.OtherUserId" />
            <div class="flex-grow-1">
                <textarea id="messageInput" class="form-control" rows="1" placeholder="اكتب رسالتك هنا..." style="border-radius:14px;resize:none;max-height:120px;padding:12px 16px;" oninput="autoResize(this)"></textarea>
            </div>
            <button type="submit" class="btn-primary-custom" style="border-radius:14px;padding:12px 20px;flex-shrink:0;" id="sendBtn">
                <i class="fas fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>

<style>
    #messagesArea::-webkit-scrollbar { width: 4px; }
    #messagesArea::-webkit-scrollbar-track { background: transparent; }
    #messagesArea::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }
    
    .typing-dots span {
        animation: dotAnim 1.4s infinite;
        font-size: 1.5rem;
        line-height: 0;
        margin: 0 1px;
    }
    .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes dotAnim {
        0%, 60%, 100% { opacity: 0.3; }
        30% { opacity: 1; }
    }
    .message-item {
        animation: slideInMsg 0.3s ease;
    }
    @@keyframes slideInMsg {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@section Scripts {
    <script>
        function autoResize(textarea) {
            textarea.style.height = 'auto';
            textarea.style.height = Math.min(textarea.scrollHeight, 120) + 'px';
        }

        // Scroll to bottom
        function scrollToBottom() {
            const area = document.getElementById('messagesArea');
            area.scrollTop = area.scrollHeight;
        }
        scrollToBottom();

        // Send message
        $('#chatForm').on('submit', function(e) {
            e.preventDefault();
            const input = $('#messageInput');
            const text = input.val().trim();
            if (!text) return;

            const receiverId = $('#receiverId').val();
            const token = $('input[name="__RequestVerificationToken"]').val();
            const btn = $('#sendBtn');
            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');

            $.post('/Chat/SendMessage', {
                receiverId: receiverId,
                messageText: text,
                __RequestVerificationToken: token
            }, function(response) {
                if (response.success) {
                    // Remove empty state if present
                    $('#messagesArea .h-100').remove();
                    
                    // Append new message
                    const msg = response.data;
                    const isMine = msg.senderId === '@currentUserId';
                    const readIcon = isMine ? '<i class="fas fa-check"></i>' : '';
                    const html = `
                        <div class="d-flex mb-3 justify-content-start message-item">
                            <div class="p-3 rounded-3" style="max-width:80%;background:var(--primary-light);border:1px solid var(--border);border-radius:16px 16px 4px 16px;">
                                <p class="mb-1 small" style="line-height:1.5;">${escapeHtml(msg.message)}</p>
                                <div class="d-flex justify-content-between align-items-center gap-3">
                                    <small class="text-muted" style="font-size:0.6rem;">${new Date(msg.sentAt).toLocaleTimeString('ar-EG', {hour:'2-digit',minute:'2-digit'})}</small>
                                    <small class="text-muted" style="font-size:0.6rem;">${readIcon}</small>
                                </div>
                            </div>
                        </div>
                    `;
                    $('#messagesArea').append(html);
                    input.val('');
                    input.css('height', 'auto');
                    scrollToBottom();
                } else {
                    alert(response.message || 'فشل الإرسال');
                }
            }).fail(function() {
                alert('خطأ في الاتصال بالخادم');
            }).always(function() {
                btn.prop('disabled', false).html('<i class="fas fa-paper-plane"></i>');
            });
        });

        // Escape HTML
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Poll for new messages every 3 seconds
        let lastMessageTime = new Date();
        setInterval(function() {
            const receiverId = $('#receiverId').val();
            if (!receiverId) return;
            
            $.get('/Chat/Thread', { otherUserId: receiverId, pageNumber: 1, _t: Date.now() }, function(html) {
                // Extract just the messages from the response
                const newMessages = $(html).find('#messagesArea').html();
                if (newMessages) {
                    const currentMsgs = $('#messagesArea').html();
                    if (currentMsgs !== newMessages) {
                        $('#messagesArea').html(newMessages);
                        scrollToBottom();
                    }
                }
            });
        }, 3000);

        // Enter to send, Shift+Enter for new line
        $('#messageInput').on('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                $('#chatForm').submit();
            }
        });
    </script>
}
