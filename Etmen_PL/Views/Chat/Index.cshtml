@using Etmen_PL.Models.ViewModels.Chat
@model ChatThreadsViewModel
@{
    ViewData["Title"] = "الرسائل";
    var isDoctor = User.IsInRole("Doctor");
    Layout = isDoctor ? "~/Views/Shared/_DoctorLayout.cshtml" : "~/Views/Shared/_PatientLayout.cshtml";
}

<div class="row g-4">
    <div class="col-12">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h5 class="fw-bold mb-1"><i class="fas fa-comments ms-2" style="color:var(--primary);"></i> المحادثات</h5>
                <p class="text-muted small mb-0">رسائلك مع المرضى والأطباء</p>
            </div>
            <a href="/Chat/Index" class="btn-outline-custom btn-sm py-1 px-3" style="font-size:0.75rem;" onclick="location.reload();">
                <i class="fas fa-sync-alt"></i> تحديث
            </a>
        </div>
    </div>

    <div class="col-12">
        <div class="dr-card animate__animated animate__fadeInUp p-0" style="overflow:hidden;">
            @if (Model.Threads.Any())
            {
                <div class="d-flex flex-column">
                    @foreach (var thread in Model.Threads.OrderByDescending(t => t.LastMessageAt))
                    {
                        <a href="/Chat/Thread?otherUserId=@thread.UserId" class="text-decoration-none">
                            <div class="d-flex align-items-center gap-3 px-4 py-3 border-bottom" style="transition:all 0.25s;border-color:var(--border);" onmouseover="this.style.background='var(--primary-light)'" onmouseout="this.style.background='transparent'">
                                <div class="sidebar-user-avatar flex-shrink-0 position-relative" style="width:48px;height:48px;background:linear-gradient(135deg,var(--primary),var(--accent));">
                                    <i class="fas fa-user" style="font-size:1rem;"></i>
                                    @if (thread.UnreadCount > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.6rem;transform:translate(-50%,-10%)!important;border:2px solid white;">
                                            @thread.UnreadCount
                                        </span>
                                    }
                                </div>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h6 class="fw-bold mb-0 text-dark">@thread.UserName</h6>
                                        <small class="text-muted" style="font-size:0.7rem;white-space:nowrap;">
                                            @thread.LastMessageAt.ToString("dd/MM HH:mm")
                                        </small>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <p class="mb-0 small text-muted text-truncate" style="max-width:250px;">
                                            @if (thread.UnreadCount > 0)
                                            {
                                                <span class="fw-bold" style="color:var(--dark);">@thread.LastMessage</span>
                                            }
                                            else
                                            {
                                                @thread.LastMessage
                                            }
                                        </p>
                                        <i class="fas fa-chevron-left text-muted" style="font-size:0.65rem;"></i>
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="far fa-comment-dots"></i></div>
                    <div class="empty-state-text">لا توجد محادثات بعد</div>
                    <p class="text-muted small mt-2">عند بدء محادثة مع مريض أو طبيب، ستظهر هنا</p>
                </div>
            }
        </div>
    </div>
</div>
