@model Etmen_PL.Models.ViewModels.Patient.PatientProfileViewModel
@using Etmen_Domain.Enums
@{
    ViewData["Title"] = "تعديل الملف الطبي والشخصي — إطمن";
    Layout = null;

    // Calculate BMI for card preview
    decimal bmi = 0;
    if (Model.Height.HasValue && Model.Weight.HasValue && Model.Height.Value > 0)
    {
        var h = Model.Height.Value / 100;
        bmi = Math.Round(Model.Weight.Value / (h * h), 1);
    }
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        :root {
            --primary:        #1A6FBF;
            --primary-dark:   #0D4C8A;
            --primary-light:  #E8F4FD;
            --accent:         #00C9A7;
            --success:        #27AE60;
            --warning:        #F39C12;
            --danger:         #E74C3C;
            --dark:           #0F1923;
            --dark-2:         #1B2A38;
            --text:           #2C3E50;
            --text-muted:     #7F8C8D;
            --border:         #DDE3EC;
            --white:          #FFFFFF;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background-color: #F4F7FC;
            color: var(--text);
            min-height: 100vh;
        }

        /* ── NAVBAR ── */
        .dashboard-nav {
            background: var(--dark);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 0.75rem 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }
        .nav-logo-icon {
            width: 40px; height: 40px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem;
            color: white;
        }
        .nav-logo-text {
            font-size: 1.4rem;
            font-weight: 800;
            color: white;
        }
        .nav-logo-text span { color: var(--accent); }

        .nav-user-badge {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.12);
            color: white;
            padding: 6px 14px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-logout {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.2);
            color: rgba(255,255,255,0.8);
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            transition: all 0.2s;
            text-decoration: none;
        }
        .btn-logout:hover {
            background: rgba(231, 76, 60, 0.1);
            border-color: var(--danger);
            color: var(--danger);
        }

        /* ── SIDEBAR ── */
        .sidebar {
            background: white;
            border-left: 1px solid var(--border);
            min-height: calc(100vh - 65px);
            padding: 2rem 1rem;
        }
        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 10px;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 0.5rem;
            transition: all 0.2s;
        }
        .sidebar-link:hover, .sidebar-link.active {
            background: var(--primary-light);
            color: var(--primary);
        }
        .sidebar-link i {
            font-size: 1.1rem;
            width: 24px;
            text-align: center;
        }

        .content-area {
            padding: 2rem;
        }

        /* ── PROFILE CARD PREVIEW ── */
        .medical-card-preview {
            background: linear-gradient(135deg, var(--dark), var(--dark-2));
            color: white;
            border-radius: 20px;
            padding: 2rem;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(15,25,35,0.15);
            margin-bottom: 2rem;
        }
        .medical-card-preview::before {
            content: '';
            position: absolute;
            bottom: -30px; right: -30px;
            width: 150px; height: 150px;
            background: rgba(26, 111, 191, 0.15);
            border-radius: 50%;
            filter: blur(40px);
        }

        .card-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--accent);
            font-weight: 700;
            margin-bottom: 4px;
        }

        .form-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 2.5rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.02);
        }

        .form-label {
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--text);
            margin-bottom: 0.5rem;
        }

        .form-control, .form-select {
            border: 1.5px solid var(--border);
            border-radius: 12px;
            padding: 12px 16px;
            font-family: 'Tajawal', sans-serif;
            font-size: 0.95rem;
            transition: all 0.2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px var(--primary-light);
        }

        .btn-submit {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: white;
            border: none;
            padding: 14px 30px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1rem;
            box-shadow: 0 4px 15px rgba(26, 111, 191, 0.3);
            transition: all 0.25s;
        }
        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(26, 111, 191, 0.45);
        }

        .bmi-bar {
            height: 8px;
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
            overflow: hidden;
            margin-top: 10px;
        }
        .bmi-bar-fill {
            height: 100%;
            border-radius: 4px;
        }
    </style>
</head>
<body>

    <!-- ── NAVBAR ── -->
    <nav class="dashboard-nav d-flex align-items-center justify-content-between">
        <a href="/" class="nav-logo">
            <div class="nav-logo-icon"><i class="fas fa-heartbeat"></i></div>
            <span class="nav-logo-text">إط<span>من</span></span>
        </a>
        <div class="d-flex align-items-center gap-3">
            <span class="nav-user-badge"><i class="fas fa-user-circle"></i> @Model.FullName</span>
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout"><i class="fas fa-sign-out-alt"></i> خروج</button>
            </form>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- ── SIDEBAR ── -->
            <div class="col-lg-2 col-md-3 d-none d-md-block sidebar">
                <a href="/PatientDashboard" class="sidebar-link">
                    <i class="fas fa-chart-pie"></i> لوحة التحكم
                </a>
                <a href="/PatientProfile" class="sidebar-link active">
                    <i class="fas fa-user-md"></i> الملف الشخصي والحيوي
                </a>
                <a href="/LabResults" class="sidebar-link">
                    <i class="fas fa-file-medical-alt"></i> رفع التحاليل (OCR)
                </a>
                <a href="/FamilyLinking" class="sidebar-link">
                    <i class="fas fa-users"></i> الارتباط العائلي
                </a>
                <a href="/Chatbot" class="sidebar-link">
                    <i class="fas fa-robot"></i> استشارة الذكاء الاصطناعي
                </a>
                <a href="/" class="sidebar-link">
                    <i class="fas fa-home"></i> الرئيسية العامة
                </a>
            </div>

            <!-- ── MAIN CONTENT ── -->
            <div class="col-lg-10 col-md-9 content-area">
                <h2 class="fw-bold mb-4">تحديث الملف الطبي والمؤشرات الحيوية</h2>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success border-0 shadow-sm mb-4" style="border-radius: 12px;">
                        <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                    </div>
                }

                <div class="row">
                    <!-- Right side: Edit Form -->
                    <div class="col-lg-8 order-lg-1 order-2">
                        <div class="form-card">
                            <form method="post" asp-controller="PatientProfile" asp-action="Index">
                                @Html.AntiForgeryToken()

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <h5 class="fw-bold mb-4 pb-2 border-bottom text-primary"><i class="fas fa-info-circle"></i> المعلومات الشخصية الأساسية</h5>
                                
                                <div class="row g-3 mb-4">
                                    <div class="col-md-6">
                                        <label asp-for="FullName" class="form-label">الاسم الكامل</label>
                                        <input asp-for="FullName" class="form-control" placeholder="أدخل اسمك بالكامل" />
                                        <span asp-validation-for="FullName" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="DateOfBirth" class="form-label">تاريخ الميلاد</label>
                                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                                        <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Gender" class="form-label">الجنس</label>
                                        <select asp-for="Gender" class="form-select">
                                            <option value="">اختر الجنس</option>
                                            <option value="Male">ذكر</option>
                                            <option value="Female">أنثى</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="BloodType" class="form-label">فصيلة الدم</label>
                                        <select asp-for="BloodType" class="form-select">
                                            <option value="">اختر فصيلة الدم</option>
                                            <option value="A+">A+</option>
                                            <option value="A-">A-</option>
                                            <option value="B+">B+</option>
                                            <option value="B-">B-</option>
                                            <option value="AB+">AB+</option>
                                            <option value="AB-">AB-</option>
                                            <option value="O+">O+</option>
                                            <option value="O-">O-</option>
                                        </select>
                                    </div>
                                </div>

                                <h5 class="fw-bold mb-4 pb-2 border-bottom text-primary"><i class="fas fa-heartbeat"></i> القياسات والمؤشرات الطبية</h5>

                                <div class="row g-3 mb-4">
                                    <div class="col-md-4">
                                        <label asp-for="Height" class="form-label">الطول (سم)</label>
                                        <input asp-for="Height" type="number" step="0.1" class="form-control" placeholder="مثال: 175" />
                                        <span asp-validation-for="Height" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="Weight" class="form-label">الوزن (كجم)</label>
                                        <input asp-for="Weight" type="number" step="0.1" class="form-control" placeholder="مثال: 72" />
                                        <span asp-validation-for="Weight" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="ActivityLevel" class="form-label">مستوى النشاط البدني</label>
                                        <select asp-for="ActivityLevel" class="form-select">
                                            <option value="@PhysicalActivityLevel.Sedentary">خامل / قليل الحركة</option>
                                            <option value="@PhysicalActivityLevel.Light">نشاط خفيف (1-3 أيام/أسبوع)</option>
                                            <option value="@PhysicalActivityLevel.Moderate">نشاط متوسط (3-5 أيام/أسبوع)</option>
                                            <option value="@PhysicalActivityLevel.Active">نشط جداً (رياضة يومية)</option>
                                            <option value="@PhysicalActivityLevel.VeryActive">نشط للغاية (رياضة شاقة)</option>
                                        </select>
                                    </div>
                                </div>

                                <h5 class="fw-bold mb-4 pb-2 border-bottom text-primary"><i class="fas fa-notes-medical"></i> السجل المرضي والحساسية</h5>

                                <div class="mb-4">
                                    <div class="form-check form-switch mb-3">
                                        <input asp-for="HasChronicDiseases" class="form-check-input" type="checkbox" id="chronicSwitch">
                                        <label class="form-check-label fw-semibold" for="chronicSwitch">هل تعاني من أي أمراض مزمنة؟</label>
                                    </div>
                                    
                                    <div class="mb-3" id="chronicNotesContainer" style="display: @(Model.HasChronicDiseases ? "block" : "none");">
                                        <label asp-for="ChronicDiseasesNotes" class="form-label">تفاصيل الأمراض المزمنة</label>
                                        <textarea asp-for="ChronicDiseasesNotes" class="form-control" rows="3" placeholder="اكتب أسماء الأمراض المزمنة والعلاجات المستمرة..."></textarea>
                                    </div>
                                </div>

                                <div class="row g-3 mb-4">
                                    <div class="col-md-6">
                                        <label asp-for="Allergies" class="form-label">حالات الحساسية</label>
                                        <textarea asp-for="Allergies" class="form-control" rows="3" placeholder="مثال: حساسية البنسلين، حساسية اللاكتوز..."></textarea>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="CurrentMedications" class="form-label">الأدوية الحالية</label>
                                        <textarea asp-for="CurrentMedications" class="form-control" rows="3" placeholder="اكتب أسماء وجرعات الأدوية التي تتناولها حالياً..."></textarea>
                                    </div>
                                </div>

                                <button type="submit" class="btn-submit w-100 mt-2"><i class="fas fa-save"></i> حفظ التغييرات والملف الطبي</button>
                            </form>
                        </div>
                    </div>

                    <!-- Left side: Live Health Card Preview -->
                    <div class="col-lg-4 order-lg-2 order-1">
                        <div class="medical-card-preview">
                            <div class="d-flex align-items-center justify-content-between mb-4">
                                <span class="fw-bold fs-5 text-white"><i class="fas fa-shield-heart text-accent"></i> البطاقة الصحية الرقمية</span>
                                <span class="badge bg-success">نشط</span>
                            </div>

                            <div class="mb-3">
                                <div class="card-label">الاسم الكامل</div>
                                <div class="fw-bold fs-5 text-white">@(string.IsNullOrEmpty(Model.FullName) ? "جاري الإدخال..." : Model.FullName)</div>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <div class="card-label">الجنس</div>
                                    <div class="fw-semibold text-white-50">@(Model.Gender == "Male" ? "ذكر" : Model.Gender == "Female" ? "أنثى" : "—")</div>
                                </div>
                                <div class="col-6">
                                    <div class="card-label">فصيلة الدم</div>
                                    <div class="fw-semibold text-white">@(string.IsNullOrEmpty(Model.BloodType) ? "—" : Model.BloodType)</div>
                                </div>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-6">
                                    <div class="card-label">الطول</div>
                                    <div class="fw-semibold text-white">@(Model.Height.HasValue ? $"{Model.Height.Value} سم" : "—")</div>
                                </div>
                                <div class="col-6">
                                    <div class="card-label">الوزن</div>
                                    <div class="fw-semibold text-white">@(Model.Weight.HasValue ? $"{Model.Weight.Value} كجم" : "—")</div>
                                </div>
                            </div>

                            <div class="border-top pt-3 border-secondary">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <div class="card-label">كتلة الجسم (BMI)</div>
                                        <div class="fw-bold fs-3 text-white">@(bmi > 0 ? bmi.ToString() : "—")</div>
                                    </div>
                                    <div class="text-start">
                                        @if (bmi > 0)
                                        {
                                            string cat = bmi switch {
                                                < 18.5m => "وزن ناقص",
                                                < 25m => "وزن مثالي",
                                                < 30m => "وزن زائد",
                                                _ => "سمنة"
                                            };
                                            string color = bmi switch {
                                                < 18.5m => "#F39C12",
                                                < 25m => "#27AE60",
                                                < 30m => "#E67E22",
                                                _ => "#E74C3C"
                                            };
                                            <span class="badge fw-semibold" style="background-color: @color">@cat</span>
                                            <div class="bmi-bar">
                                                <div class="bmi-bar-fill" style="width: @(Math.Min(100, bmi * 2.5m))%; background-color: @color"></div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Toggle Chronic Notes container based on Switch status
        $('#chronicSwitch').on('change', function () {
            if (this.checked) {
                $('#chronicNotesContainer').slideDown(250);
            } else {
                $('#chronicNotesContainer').slideUp(200);
            }
        });
    </script>
</body>
</html>
