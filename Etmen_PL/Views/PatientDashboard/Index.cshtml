@model Etmen_PL.Models.ViewModels.Patient.PatientDashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم — إطمن";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        :root {
            --primary:        #1A6FBF;
            --primary-dark:   #0D4C8A;
            --primary-light:  #E8F4FD;
            --accent:         #00C9A7;
            --success:        #27AE60;
            --warning:        #F39C12;
            --danger:         #E74C3C;
            --dark:           #0F1923;
            --dark-2:         #1B2A38;
            --text:           #2C3E50;
            --text-muted:     #7F8C8D;
            --border:         #DDE3EC;
            --white:          #FFFFFF;
            --glass:          rgba(255,255,255,0.08);
            --glass-border:   rgba(255,255,255,0.15);
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background-color: #F4F7FC;
            color: var(--text);
            min-height: 100vh;
        }

        /* ── NAVBAR ── */
        .dashboard-nav {
            background: var(--dark);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 0.75rem 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }
        .nav-logo-icon {
            width: 40px; height: 40px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem;
            color: white;
            box-shadow: 0 0 15px rgba(26, 111, 191, 0.4);
        }
        .nav-logo-text {
            font-size: 1.4rem;
            font-weight: 800;
            color: white;
        }
        .nav-logo-text span { color: var(--accent); }

        .nav-user-badge {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.12);
            color: white;
            padding: 6px 14px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-logout {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.2);
            color: rgba(255,255,255,0.8);
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            transition: all 0.2s;
            text-decoration: none;
        }
        .btn-logout:hover {
            background: rgba(231, 76, 60, 0.1);
            border-color: var(--danger);
            color: var(--danger);
        }

        /* ── SIDEBAR / LAYOUT ── */
        .sidebar {
            background: white;
            border-left: 1px solid var(--border);
            min-height: calc(100vh - 65px);
            padding: 2rem 1rem;
        }
        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 10px;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 0.5rem;
            transition: all 0.2s;
        }
        .sidebar-link:hover, .sidebar-link.active {
            background: var(--primary-light);
            color: var(--primary);
        }
        .sidebar-link i {
            font-size: 1.1rem;
            width: 24px;
            text-align: center;
        }

        /* ── CONTENT CARDS ── */
        .content-area {
            padding: 2rem;
        }
        .welcome-card {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-radius: 20px;
            padding: 2.5rem;
            color: white;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(26,111,191,0.15);
            margin-bottom: 2rem;
        }
        .welcome-card::before {
            content: '';
            position: absolute;
            top: -50px; left: -50px;
            width: 200px; height: 200px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
        }

        .metric-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            transition: transform 0.2s, box-shadow 0.2s;
            height: 100%;
        }
        .metric-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.06);
        }
        .metric-icon {
            width: 48px; height: 48px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem;
            margin-bottom: 1rem;
        }

        /* Quick Action Grid */
        .action-card {
            background: white;
            border: 1.5px solid var(--border);
            border-radius: 16px;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            cursor: pointer;
            text-decoration: none;
            color: var(--text);
            transition: all 0.25s;
            height: 100%;
        }
        .action-card:hover {
            border-color: var(--primary);
            box-shadow: 0 10px 20px rgba(26,111,191,0.08);
            transform: translateY(-3px);
        }
        .action-icon {
            width: 55px; height: 55px;
            border-radius: 50%;
            background: var(--primary-light);
            color: var(--primary);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
            margin-bottom: 1rem;
            transition: all 0.2s;
        }
        .action-card:hover .action-icon {
            background: var(--primary);
            color: white;
            transform: scale(1.1);
        }

        .list-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        }
        .list-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid #F0F3F7;
        }
        .list-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .badge-pulse {
            display: inline-block;
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--danger);
            animation: pulse 1.5s infinite;
        }
        @@keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.4); opacity: 0.5; }
        }
    </style>
</head>
<body>

    <!-- ── NAVBAR ── -->
    <nav class="dashboard-nav d-flex align-items-center justify-content-between">
        <a href="/" class="nav-logo">
            <div class="nav-logo-icon"><i class="fas fa-heartbeat"></i></div>
            <span class="nav-logo-text">إط<span>من</span></span>
        </a>
        <div class="d-flex align-items-center gap-3">
            <span class="nav-user-badge"><i class="fas fa-user-circle"></i> @Model.PatientName</span>
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout"><i class="fas fa-sign-out-alt"></i> خروج</button>
            </form>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- ── SIDEBAR ── -->
            <div class="col-lg-2 col-md-3 d-none d-md-block sidebar">
                <a href="/PatientDashboard" class="sidebar-link active">
                    <i class="fas fa-chart-pie"></i> لوحة التحكم
                </a>
                <a href="/PatientProfile" class="sidebar-link">
                    <i class="fas fa-user-md"></i> الملف الشخصي والحيوي
                </a>
                <a href="/LabResults" class="sidebar-link">
                    <i class="fas fa-file-medical-alt"></i> رفع التحاليل (OCR)
                </a>
                <a href="/FamilyLinking" class="sidebar-link">
                    <i class="fas fa-users"></i> الارتباط العائلي
                </a>
                <a href="/Chatbot" class="sidebar-link">
                    <i class="fas fa-robot"></i> استشارة الذكاء الاصطناعي
                </a>
                <a href="/" class="sidebar-link">
                    <i class="fas fa-home"></i> الرئيسية العامة
                </a>
            </div>

            <!-- ── MAIN CONTENT ── -->
            <div class="col-lg-10 col-md-9 content-area">
                
                <!-- Welcome Card -->
                <div class="welcome-card">
                    <h1 class="fw-bold mb-2">مرحباً، @Model.PatientName 👋</h1>
                    <p class="mb-0 opacity-75">نتمنى لك يوماً صحياً ومباركاً. إليك آخر التحديثات بخصوص ملفك الطبي ومؤشراتك الحيوية.</p>
                </div>

                <!-- Alert Messages -->
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert" style="border-radius:12px;">
                        <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert" style="border-radius:12px;">
                        <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <!-- Stats Grid -->
                <div class="row g-4 mb-4">
                    <!-- BMI Card -->
                    <div class="col-md-4">
                        <div class="metric-card">
                            <div class="metric-icon" style="background:#E8F4FD; color:var(--primary);">
                                <i class="fas fa-weight"></i>
                            </div>
                            <span class="text-muted d-block mb-1">مؤشر كتلة الجسم (BMI)</span>
                            <h3 class="fw-bold mb-2">
                                @(Model.LatestBmi.HasValue ? Model.LatestBmi.Value.ToString("F1") : "—")
                            </h3>
                            @if (!string.IsNullOrEmpty(Model.LatestBmiCategory))
                            {
                                string categoryAr = Model.LatestBmiCategory switch {
                                    "Underweight" => "نقص في الوزن",
                                    "Normal" => "وزن مثالي",
                                    "Overweight" => "زيادة في الوزن",
                                    "Obese" => "سمنة مفرطة",
                                    _ => Model.LatestBmiCategory
                                };
                                string categoryClass = Model.LatestBmiCategory == "Normal" ? "text-success" : "text-warning";
                                <span class="badge bg-light @categoryClass fw-semibold">@categoryAr</span>
                            }
                        </div>
                    </div>

                    <!-- Alerts Count -->
                    <div class="col-md-4">
                        <div class="metric-card">
                            <div class="metric-icon" style="background:#FFF5E5; color:var(--warning);">
                                <i class="fas fa-bell"></i>
                            </div>
                            <span class="text-muted d-block mb-1">التنبيهات غير المقروءة</span>
                            <h3 class="fw-bold mb-2">@Model.UnreadAlertsCount</h3>
                            @if (Model.UnreadAlertsCount > 0)
                            {
                                <span class="badge bg-warning-subtle text-warning fw-semibold">
                                    <span class="badge-pulse me-1"></span> تحتاج مراجعة
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success-subtle text-success fw-semibold">كل شيء سليم</span>
                            }
                        </div>
                    </div>

                    <!-- Appointments Count -->
                    <div class="col-md-4">
                        <div class="metric-card">
                            <div class="metric-icon" style="background:#E8FDF8; color:var(--accent);">
                                <i class="fas fa-calendar-alt"></i>
                            </div>
                            <span class="text-muted d-block mb-1">المواعيد القادمة</span>
                            <h3 class="fw-bold mb-2">@Model.UpcomingAppointmentsCount</h3>
                            <span class="badge bg-light text-muted fw-semibold">خلال هذا الأسبوع</span>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <h4 class="fw-bold mb-3 mt-5">إجراءات سريعة</h4>
                <div class="row g-4 mb-5">
                    <div class="col-md-3 col-6">
                        <a href="/PatientProfile" class="action-card">
                            <div class="action-icon"><i class="fas fa-user-edit"></i></div>
                            <span class="fw-bold">تحديث المؤشرات</span>
                        </a>
                    </div>
                    <div class="col-md-3 col-6">
                        <a href="/LabResults" class="action-card">
                            <div class="action-icon"><i class="fas fa-file-upload"></i></div>
                            <span class="fw-bold">رفع تحليل جديد</span>
                        </a>
                    </div>
                    <div class="col-md-3 col-6">
                        <a href="/FamilyLinking" class="action-card">
                            <div class="action-icon"><i class="fas fa-user-plus"></i></div>
                            <span class="fw-bold">ربط حساب عائلي</span>
                        </a>
                    </div>
                    <div class="col-md-3 col-6">
                        <a href="/Chatbot" class="action-card">
                            <div class="action-icon"><i class="fas fa-brain"></i></div>
                            <span class="fw-bold">استشارة ذكية</span>
                        </a>
                    </div>
                </div>

                <!-- Lists Section -->
                <div class="row g-4">
                    <!-- Upcoming Appointments -->
                    <div class="col-md-6">
                        <div class="list-card">
                            <h5 class="fw-bold mb-3"><i class="fas fa-calendar-check text-primary me-2"></i> المواعيد القادمة</h5>
                            @if (Model.UpcomingAppointments.Any())
                            {
                                @foreach (var apt in Model.UpcomingAppointments)
                                {
                                    <div class="list-item">
                                        <div>
                                            <span class="fw-bold d-block">د. @apt.DoctorName</span>
                                            <small class="text-muted">@apt.Date.ToString("yyyy/MM/dd - hh:mm tt")</small>
                                        </div>
                                        <div>
                                            @{
                                                string badgeClass = apt.Status == "Confirmed" ? "bg-success" : "bg-warning";
                                                string statusAr = apt.Status == "Confirmed" ? "مؤكد" : "معلق";
                                            }
                                            <span class="badge @badgeClass">@statusAr</span>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-4 text-muted">
                                    <i class="far fa-calendar-times mb-2 fs-3"></i>
                                    <p class="mb-0 small">لا توجد مواعيد قادمة حالياً</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Recent Alerts -->
                    <div class="col-md-6">
                        <div class="list-card">
                            <h5 class="fw-bold mb-3"><i class="fas fa-exclamation-triangle text-warning me-2"></i> تنبيهات صحية أخيرة</h5>
                            @if (Model.RecentAlerts.Any())
                            {
                                @foreach (var alert in Model.RecentAlerts)
                                {
                                    <div class="list-item">
                                        <div>
                                            <span class="fw-semibold d-block text-danger">@alert.Title</span>
                                            <small class="text-muted">@alert.CreatedAt.ToString("yyyy/MM/dd")</small>
                                        </div>
                                        <div>
                                            @if (!alert.IsRead)
                                            {
                                                <span class="badge bg-danger">جديد</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-muted">مقروء</span>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-4 text-muted">
                                    <i class="far fa-bell-slash mb-2 fs-3"></i>
                                    <p class="mb-0 small">لا توجد تنبيهات صحية جديدة</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
