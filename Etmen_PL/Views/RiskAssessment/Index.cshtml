@model Etmen_PL.Models.ViewModels.Patient.RiskAssessmentInputViewModel
@{
    ViewData["Title"] = "تقييم المخاطر الصحية الذاتي";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    var activeCrisis = ViewBag.ActiveCrisis as Etmen_BLL.DTOs.Crisis.CrisisConfigurationDto;
    var isCrisisMode = activeCrisis != null && activeCrisis.IsActive && activeCrisis.SystemMode == Etmen_Domain.Enums.SystemMode.Crisis;
}

<style>
    /* Wizard Steps styling */
    .wizard-step-indicator {
        display: flex;
        justify-content: space-between;
        margin-bottom: 3rem;
        position: relative;
    }
    .wizard-step-indicator::before {
        content: '';
        position: absolute;
        top: 24px; left: 0; right: 0;
        height: 3px;
        background-color: var(--border);
        z-index: 1;
    }
    .wizard-progress-bar {
        position: absolute;
        top: 24px; right: 0;
        height: 3px;
        background-color: var(--primary);
        z-index: 2;
        width: 0%;
        transition: width 0.4s ease;
    }
    .step-node {
        width: 50px; height: 50px;
        border-radius: 50%;
        background-color: white;
        border: 3px solid var(--border);
        display: flex; align-items: center; justify-content: center;
        font-weight: 800;
        color: var(--text-muted);
        position: relative;
        z-index: 3;
        transition: all 0.4s;
    }
    .step-node.active {
        border-color: var(--primary);
        color: var(--primary);
        box-shadow: 0 0 15px rgba(26,111,191,0.25);
    }
    .step-node.complete {
        background-color: var(--primary);
        border-color: var(--primary);
        color: white;
    }
    .step-node-label {
        position: absolute;
        top: 55px;
        white-space: nowrap;
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--text-muted);
    }
    .step-node.active .step-node-label {
        color: var(--primary-dark);
    }

    .form-group-medical {
        background: #F8FAFC;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem;
        transition: all 0.25s;
    }
    .form-group-medical:focus-within {
        background: white;
        border-color: var(--primary);
        box-shadow: 0 0 10px rgba(26,111,191,0.08);
    }
    .input-unit-badge {
        background: var(--border);
        color: var(--text);
        font-weight: 700;
        border-radius: 0 8px 8px 0;
        display: flex; align-items: center; padding: 0 12px;
    }

    .error-summary-alert {
        background: linear-gradient(135deg, #FEF2F2 0%, #FEE2E2 100%);
        border: 2px solid #DC2626;
        border-radius: 14px;
        padding: 1rem 1.25rem;
        color: #991B1B;
        display: none;
        animation: errorShake 0.5s ease;
    }
    .error-summary-alert.show {
        display: flex;
    }
    @@keyframes errorShake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-8px); }
        75% { transform: translateX(8px); }
    }
    .form-group-medical.has-error {
        border-color: #DC2626 !important;
        background: #FEF2F2 !important;
        box-shadow: 0 0 0 3px rgba(220,38,38,0.1) !important;
    }
    .form-group-medical.has-error .input-unit-badge {
        background: #FCA5A5;
        color: #991B1B;
    }
    .field-error-text {
        color: #DC2626;
        font-size: 0.8rem;
        font-weight: 600;
        margin-top: 4px;
        display: flex;
        align-items: center;
        gap: 4px;
    }
    .field-error-text i {
        font-size: 0.75rem;
    }
    .input-validation-error {
        border-color: #DC2626 !important;
        background-color: #FEF2F2 !important;
    }

    /* Checkbox card styling */
    .card-checkbox {
        border: 2px solid var(--border) !important;
        border-radius: 12px;
        transition: all 0.2s ease;
    }
    .card-checkbox.checked {
        border-color: var(--primary) !important;
        background-color: var(--primary-light) !important;
    }
</style>

<div class="row g-4 justify-content-center">
    <div class="col-lg-9 animate__animated animate__fadeInUp">
        <div class="med-card p-5">
            <div class="text-center mb-5">
                <span class="badge bg-primary-light text-primary px-3 py-2 fw-bold mb-3" style="border-radius:8px;">
                    <i class="fas fa-brain"></i> فحص سريري ذكي بالذكاء الاصطناعي
                </span>
                <h2 class="fw-black text-dark">تقييم المخاطر الصحية والذعر</h2>
                <p class="text-muted max-width-600 mx-auto">قم بإدخال علاماتك الحيوية أو أعراض الأزمة الحالية لحساب مؤشر الخطر وحالة الطوارئ.</p>
            </div>

            <!-- Steps Indicator -->
            <div class="wizard-step-indicator">
                <div class="wizard-progress-bar" id="wizardProgress"></div>
                <div class="step-node complete" id="node-1">
                    1 <span class="step-node-label">@(isCrisisMode ? "أعراض الأزمة" : "المؤشرات الحيوية")</span>
                </div>
                <div class="step-node" id="node-2">
                    2 <span class="step-node-label">@(isCrisisMode ? "الموقع الجغرافي" : "الأعراض والموقع")</span>
                </div>
            </div>

            <!-- Main Form -->
            <form method="post" asp-controller="RiskAssessment" asp-action="Index" id="assessmentForm">
                @Html.AntiForgeryToken()
                <div id="errorSummaryContainer" class="error-summary-alert align-items-start gap-3 mb-4 @(ViewData.ModelState.ErrorCount > 0 ? "show" : "")">
                    <i class="fas fa-exclamation-circle mt-1" style="font-size: 1.25rem;"></i>
                    <div>
                        <h6 class="fw-bold mb-1" style="color: #991B1B;">توجد أخطاء في البيانات المدخلة</h6>
                        <div asp-validation-summary="ModelOnly" class="mb-0 small" style="color: #991B1B; list-style: none; padding: 0; margin: 0;"></div>
                        <ul id="clientErrors" class="mb-0 small" style="color: #991B1B; padding-right: 1rem; margin-top: 4px; display: none;"></ul>
                    </div>
                    <button type="button" class="btn-close me-auto" data-bs-dismiss="alert" aria-label="Close" onclick="this.parentElement.classList.remove('show')"></button>
                </div>

                <!-- STEP 1: Content -->
                <div id="step-1-content">
                    @if (isCrisisMode)
                    {
                        <div class="alert alert-warning d-flex align-items-center gap-3 py-3 px-4 mb-4 animate__animated animate__pulse" style="border-radius:12px;">
                            <div class="fs-3 text-warning"><i class="fas fa-triangle-exclamation"></i></div>
                            <div>
                                <span class="fw-bold d-block text-dark">تم تفعيل وضع طوارئ الأزمات: @activeCrisis?.CrisisName</span>
                                <span class="small text-muted">في هذا الوضع، سيتم تقييم مستوى خطورة حالتك بناءً على أعراض الوباء النشط فقط. المؤشرات الحيوية غير مطلوبة حالياً.</span>
                            </div>
                        </div>

                        <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-viruses"></i> الخطوة 1: اختر الأعراض التي تعاني منها حالياً</h5>
                        
                        <input type="hidden" asp-for="Symptoms" id="symptomsHidden" />
                        <div class="row g-3 mb-4">
                            @foreach (var symptom in activeCrisis?.SymptomWeights ?? Enumerable.Empty<Etmen_BLL.DTOs.Crisis.SymptomWeightDto>())
                            {
                                <div class="col-md-6 col-12">
                                    <div class="form-group-medical card-checkbox p-3 d-flex align-items-center gap-3" style="cursor:pointer;" onclick="toggleCheckbox(this)">
                                        <input class="form-check-input symptom-checkbox" type="checkbox" value="@symptom.SymptomName" id="symptom_@symptom.SymptomName" style="cursor:pointer; width: 22px; height: 22px;" onchange="updateSymptomsString()" onclick="event.stopPropagation();" />
                                        <label class="form-check-label fw-bold text-dark m-0" for="symptom_@symptom.SymptomName" style="cursor:pointer; user-select: none;">
                                            @symptom.SymptomName
                                            @if (symptom.IsEmergencySymptom)
                                            {
                                                <span class="badge bg-danger ms-2">عرض حرج</span>
                                            }
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Optional Vitals section inside Step 1 in Crisis Mode -->
                        <div class="mt-4 border-top pt-4">
                            <h5 class="fw-bold mb-3 text-secondary text-start"><i class="fas fa-heartbeat text-primary"></i> المؤشرات الحيوية المفحوصة (اختياري)</h5>
                            <p class="small text-muted text-start mb-4">يمكنك إدخال علاماتك الحيوية أدناه لمساعدتنا في حساب تقييم NEWS2 السريري لمزيد من الدقة.</p>
                            
                            <div class="row g-4 mb-4 text-start">
                                <!-- HeartRate (optional) -->
                                <div class="col-md-6">
                                    <div class="form-group-medical">
                                        <label asp-for="HeartRate" class="form-label fw-bold">معدل نبضات القلب</label>
                                        <div class="input-group">
                                            <input asp-for="HeartRate" type="number" class="form-control" placeholder="مثال: 72" />
                                            <span class="input-unit-badge">نبضة/دقيقة</span>
                                        </div>
                                    </div>
                                </div>
                                <!-- Temperature (optional) -->
                                <div class="col-md-6">
                                    <div class="form-group-medical">
                                        <label asp-for="Temperature" class="form-label fw-bold">درجة حرارة الجسم</label>
                                        <div class="input-group">
                                            <input asp-for="Temperature" type="number" step="0.1" class="form-control" placeholder="مثال: 37.0" />
                                            <span class="input-unit-badge">مئوية °C</span>
                                        </div>
                                    </div>
                                </div>
                                <!-- SystolicBP (optional) -->
                                <div class="col-md-6">
                                    <div class="form-group-medical">
                                        <label asp-for="SystolicBP" class="form-label fw-bold">ضغط الدم الانقباضي (العالي)</label>
                                        <div class="input-group">
                                            <input asp-for="SystolicBP" type="number" class="form-control" placeholder="مثال: 120" />
                                            <span class="input-unit-badge">mmHg</span>
                                        </div>
                                    </div>
                                </div>
                                <!-- DiastolicBP (optional) -->
                                <div class="col-md-6">
                                    <div class="form-group-medical">
                                        <label asp-for="DiastolicBP" class="form-label fw-bold">ضغط الدم الانبساطي (المنخفض)</label>
                                        <div class="input-group">
                                            <input asp-for="DiastolicBP" type="number" class="form-control" placeholder="مثال: 80" />
                                            <span class="input-unit-badge">mmHg</span>
                                        </div>
                                    </div>
                                </div>
                                <!-- OxygenSaturation (optional) -->
                                <div class="col-md-6">
                                    <div class="form-group-medical">
                                        <label asp-for="OxygenSaturation" class="form-label fw-bold">تشبع الأكسجين في الدم</label>
                                        <div class="input-group">
                                            <input asp-for="OxygenSaturation" type="number" class="form-control" placeholder="مثال: 98" />
                                            <span class="input-unit-badge">% SpO2</span>
                                        </div>
                                    </div>
                                </div>
                                <!-- BloodSugar (optional) -->
                                <div class="col-md-6">
                                    <div class="form-group-medical">
                                        <label asp-for="BloodSugar" class="form-label fw-bold">مستوى السكر في الدم</label>
                                        <div class="input-group">
                                            <input asp-for="BloodSugar" type="number" class="form-control" placeholder="مثال: 100" />
                                            <span class="input-unit-badge">mg/dL</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-heartbeat"></i> الخطوة 1: أدخل علاماتك الحيوية الحالية</h5>
                        
                        <div class="row g-4 mb-4">
                            <!-- Pulse -->
                            <div class="col-md-6">
                                <div class="form-group-medical" id="field-heartRate">
                                    <label asp-for="HeartRate" class="form-label fw-bold">معدل نبضات القلب</label>
                                    <div class="input-group">
                                        <input asp-for="HeartRate" type="number" class="form-control" placeholder="مثال: 72" required />
                                        <span class="input-unit-badge">نبضة/دقيقة</span>
                                    </div>
                                    <span asp-validation-for="HeartRate" class="field-error-text"></span>
                                </div>
                            </div>

                            <!-- Temperature -->
                            <div class="col-md-6">
                                <div class="form-group-medical" id="field-temperature">
                                    <label asp-for="Temperature" class="form-label fw-bold">درجة حرارة الجسم</label>
                                    <div class="input-group">
                                        <input asp-for="Temperature" type="number" step="0.1" class="form-control" placeholder="مثال: 37.0" required />
                                        <span class="input-unit-badge">مئوية °C</span>
                                    </div>
                                    <span asp-validation-for="Temperature" class="field-error-text"></span>
                                </div>
                            </div>

                            <!-- BP Systolic -->
                            <div class="col-md-6">
                                <div class="form-group-medical" id="field-systolicBP">
                                    <label asp-for="SystolicBP" class="form-label fw-bold">ضغط الدم الانقباضي (العالي)</label>
                                    <div class="input-group">
                                        <input asp-for="SystolicBP" type="number" class="form-control" placeholder="مثال: 120" required />
                                        <span class="input-unit-badge">mmHg</span>
                                    </div>
                                    <span asp-validation-for="SystolicBP" class="field-error-text"></span>
                                </div>
                            </div>

                            <!-- BP Diastolic -->
                            <div class="col-md-6">
                                <div class="form-group-medical" id="field-diastolicBP">
                                    <label asp-for="DiastolicBP" class="form-label fw-bold">ضغط الدم الانبساطي (المنخفض)</label>
                                    <div class="input-group">
                                        <input asp-for="DiastolicBP" type="number" class="form-control" placeholder="مثال: 80" required />
                                        <span class="input-unit-badge">mmHg</span>
                                    </div>
                                    <span asp-validation-for="DiastolicBP" class="field-error-text"></span>
                                </div>
                            </div>

                            <!-- Oxygen -->
                            <div class="col-md-6">
                                <div class="form-group-medical" id="field-oxygenSaturation">
                                    <label asp-for="OxygenSaturation" class="form-label fw-bold">تشبع الأكسجين في الدم</label>
                                    <div class="input-group">
                                        <input asp-for="OxygenSaturation" type="number" class="form-control" placeholder="مثال: 98" required />
                                        <span class="input-unit-badge">% SpO2</span>
                                    </div>
                                    <span asp-validation-for="OxygenSaturation" class="field-error-text"></span>
                                </div>
                            </div>

                            <!-- Blood Sugar -->
                            <div class="col-md-6">
                                <div class="form-group-medical" id="field-bloodSugar">
                                    <label asp-for="BloodSugar" class="form-label fw-bold">مستوى السكر في الدم</label>
                                    <div class="input-group">
                                        <input asp-for="BloodSugar" type="number" class="form-control" placeholder="مثال: 100" required />
                                        <span class="input-unit-badge">mg/dL</span>
                                    </div>
                                    <span asp-validation-for="BloodSugar" class="field-error-text"></span>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="d-flex justify-content-end">
                        <button type="button" class="btn btn-primary px-5 py-3 fw-bold" style="border-radius:12px;" onclick="goToStep(2)">
                            التالي: @(isCrisisMode ? "تحديد الموقع" : "الأعراض والموقع") <i class="fas fa-arrow-left"></i>
                        </button>
                    </div>
                </div>

                <!-- STEP 2: Content -->
                <div id="step-2-content" style="display:none;">
                    <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-location-dot"></i> الخطوة 2: تحديد موقعك الجغرافي</h5>
                    
                    @if (!isCrisisMode)
                    {
                        <div class="mb-4" id="field-symptoms">
                            <label asp-for="Symptoms" class="form-label fw-bold">اكتب الأعراض التي تشعر بها حالياً بالتفصيل</label>
                            <textarea asp-for="Symptoms" class="form-control" rows="4" style="border-radius:12px;" placeholder="اكتب الأعراض مثل: سعال جاف، ضيق تنفس، إرهاق شديد، ألم بالمفاصل..."></textarea>
                            <span asp-validation-for="Symptoms" class="field-error-text"></span>
                        </div>
                    }

                    <!-- Hidden location fields -->
                    <input type="hidden" asp-for="Latitude" id="gpsLat" value="30.0444" />
                    <input type="hidden" asp-for="Longitude" id="gpsLng" value="31.2357" />

                    <div class="alert alert-info d-flex align-items-center gap-3 py-3 px-4 mb-4" style="border-radius:12px;">
                        <div class="fs-3 text-primary"><i class="fas fa-map-marker-alt"></i></div>
                        <div>
                            <span class="fw-bold d-block small">تحديد البؤر الجغرافية الموبوءة</span>
                            <span class="small text-muted" id="gpsStatus">جاري استدعاء إحداثيات موقعك لتقييم مدى قربك من مناطق تفشي الأوبئة...</span>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-light px-4 py-3 fw-bold" style="border-radius:12px;" onclick="goToStep(1)">
                            <i class="fas fa-arrow-right"></i> السابق
                        </button>
                        <button type="submit" class="btn btn-submit w-100 py-3"><i class="fas fa-calculator"></i> حساب مؤشر الخطورة السريرية</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Highlight invalid fields on load (after server-side validation)
        $(document).ready(function() {
            $('.input-validation-error').each(function() {
                var $container = $(this).closest('.form-group-medical');
                if ($container.length) {
                    $container.addClass('has-error');
                }
            });
            if ($('.input-validation-error').length > 0) {
                $('#errorSummaryContainer').addClass('show');
            }
        });

        function toggleCheckbox(element) {
            var checkbox = $(element).find('.symptom-checkbox');
            checkbox.prop('checked', !checkbox.prop('checked'));
            if (checkbox.prop('checked')) {
                $(element).addClass('checked');
            } else {
                $(element).removeClass('checked');
            }
            updateSymptomsString();
        }

        function updateSymptomsString() {
            var checkedSymptoms = [];
            $('.symptom-checkbox:checked').each(function() {
                checkedSymptoms.push($(this).val());
            });
            $('#symptomsHidden').val(checkedSymptoms.join(', '));
        }

        function goToStep(stepNum) {
            if (stepNum === 2) {
                @if (!isCrisisMode)
                {
                    <text>
                    // Validate vitals in normal mode
                    var step1Fields = $('#step-1-content').find('input[required]');
                    var valid = true;
                    var errorList = [];
                    step1Fields.each(function() {
                        var fieldName = $(this).closest('.form-group-medical').find('label').text().trim();
                        if ($(this).val().trim() === '') {
                            $(this).closest('.form-group-medical').addClass('has-error');
                            errorList.push(fieldName || 'حقل مطلوب');
                            valid = false;
                        } else {
                            $(this).closest('.form-group-medical').removeClass('has-error');
                        }
                    });

                    if (!valid) {
                        var alertContainer = $('#errorSummaryContainer');
                        alertContainer.addClass('show');
                        var listHtml = '<li>' + errorList.join('</li><li>') + '</li>';
                        $('#clientErrors').html(listHtml).show();
                        return;
                    }
                    </text>
                }

                $('#clientErrors').hide();
                $('#errorSummaryContainer').removeClass('show');

                // Show step 2
                $('#step-1-content').hide();
                $('#step-2-content').fadeIn(300);
                
                // Update Indicators
                $('#node-2').addClass('active');
                $('#wizardProgress').css('width', '50%');

                // Trigger location fetch
                fetchGpsCoords();
            } else if (stepNum === 1) {
                // Show step 1
                $('#step-2-content').hide();
                $('#step-1-content').fadeIn(300);
                
                // Update Indicators
                $('#node-2').removeClass('active');
                $('#wizardProgress').css('width', '0%');
            }
        }

        function fetchGpsCoords() {
            if ("geolocation" in navigator) {
                navigator.geolocation.getCurrentPosition(
                    function(position) {
                        $('#gpsLat').val(position.coords.latitude.toFixed(6));
                        $('#gpsLng').val(position.coords.longitude.toFixed(6));
                        $('#gpsStatus').html('<i class="fas fa-check text-success"></i> تم تحديد الإحداثيات بنجاح، سيتم حساب معامل تفشي الأوبئة بناءً عليها.');
                    },
                    function(error) {
                        console.warn("Location error:", error.message);
                        $('#gpsStatus').html('<i class="fas fa-exclamation-triangle text-warning"></i> لم نتمكن من تحديد موقعك بدقة، سيتم حساب التقييم بالطريقة القياسية.');
                    },
                    { enableHighAccuracy: true, timeout: 8000 }
                );
            }
        }
    </script>
}
