@using Etmen_PL.Models.ViewModels.Doctor
@model CreateAvailableSlotViewModel
@{
    ViewData["Title"] = "إضافة موعد متاح";
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="dr-card animate__animated animate__fadeInUp">
            <div class="dr-card-header">
                <h5 class="dr-card-title"><i class="fas fa-plus-circle"></i> إضافة موعد متاح</h5>
                <a href="/DoctorSlots" class="btn-outline-custom btn-sm py-1 px-3" style="font-size:0.75rem;">
                    <i class="fas fa-arrow-left ms-1"></i> العودة
                </a>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="custom-alert custom-alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="SlotDate" class="form-label">التاريخ</label>
                    <input asp-for="SlotDate" class="form-control" type="date" />
                    <span asp-validation-for="SlotDate" class="text-danger small fw-bold"></span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="StartTime" class="form-label">وقت البداية</label>
                        <input asp-for="StartTime" class="form-control" type="time" />
                        <span asp-validation-for="StartTime" class="text-danger small fw-bold"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndTime" class="form-label">وقت النهاية</label>
                        <input asp-for="EndTime" class="form-control" type="time" />
                        <span asp-validation-for="EndTime" class="text-danger small fw-bold"></span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom flex-fill">
                        <i class="fas fa-save"></i> حفظ
                    </button>
                    <a href="/DoctorSlots" class="btn-outline-custom flex-fill text-center">
                        إلغاء
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
