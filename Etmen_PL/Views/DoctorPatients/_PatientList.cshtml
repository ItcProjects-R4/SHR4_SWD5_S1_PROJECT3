@model List<Etmen_BLL.DTOs.Doctor.PatientSearchDto>

<table class="dr-table">
    <thead>
        <tr>
            <th>الاسم</th>
            <th>رقم الهاتف</th>
            <th>البريد الإلكتروني</th>
            <th>تاريخ الميلاد</th>
            <th>فصيلة الدم</th>
            <th>أمراض مزمنة</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            @foreach (var pt in Model)
            {
                <tr>
                    <td class="fw-bold">@pt.SearchTerm</td>
                    <td dir="ltr" style="direction:ltr;">-</td>
                    <td>-</td>
                    <td>-</td>
                    <td>-</td>
                    <td>-</td>
                    <td>
                        <a href="/DoctorPatients/Details/0" class="table-action-btn" title="عرض الملف">
                            <i class="fas fa-eye"></i>
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7">
                    <div class="empty-state py-4">
                        <div class="empty-state-icon"><i class="fas fa-search"></i></div>
                        <div class="empty-state-text">لا توجد نتائج</div>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
