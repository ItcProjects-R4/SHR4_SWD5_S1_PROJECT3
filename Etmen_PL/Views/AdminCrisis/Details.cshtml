@model Etmen_BLL.DTOs.Crisis.CrisisConfigurationDto
@using Etmen_BLL.DTOs.Crisis
@{
    ViewData["Title"] = "تفاصيل الأزمة والأوزان";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var stats = ViewData["Stats"] as CrisisStatsDto;
}

<style>
    .metric-small-card {
        border-radius: 14px;
        padding: 16px;
        background: #F9FBFC;
        border: 1px solid var(--card-border);
        transition: all 0.3s;
    }
    .metric-small-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }
    .weight-input-group {
        max-width: 120px;
    }
    .badge-pill-custom {
        font-size: 0.75rem;
        font-weight: 800;
        padding: 4px 12px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .badge-active { background: #E8F8F5; color: #27AE60; }
    .badge-inactive { background: #F5F7F8; color: #7F8C8D; }
    .badge-emergency { background: #FDE8E8; color: #E74C3C; }
    .badge-medium { background: #FFF9E6; color: #F39C12; }

    .threshold-progress {
        height: 8px;
        border-radius: 4px;
        background-color: #E2E8F0;
        overflow: hidden;
    }
</style>

<div class="row g-4 animate__animated animate__fadeIn">
    <!-- Header -->
    <div class="col-12 d-flex align-items-center justify-content-between flex-wrap gap-3 mb-2">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <a href="/AdminCrisis" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                    <i class="fas fa-arrow-right"></i> العودة للقائمة
                </a>
                @if (Model.IsActive)
                {
                    <span class="badge-pill-custom badge-active">
                        <span class="spinner-grow spinner-grow-sm text-success" role="status" style="width: 8px; height: 8px;"></span>
                        أزمة نشطة حالياً
                    </span>
                }
                else
                {
                    <span class="badge-pill-custom badge-inactive">غير نشطة</span>
                }
            </div>
            <h2 class="fw-900 m-0" style="font-weight: 900;">تفاصيل الأزمة: @Model.CrisisName</h2>
            <p class="text-muted small mb-0">
                <i class="fas fa-sliders me-1"></i> إدارة أوزان الأعراض وتصنيفات فرز الحالات وتتبع المؤشرات الإحصائية.
            </p>
        </div>
        <div class="d-flex gap-2">
            <a href="/AdminCrisis/Edit/@Model.Id" class="btn btn-outline-primary rounded-pill px-4 py-2 fw-800">
                <i class="fas fa-edit me-1"></i> تعديل الإعدادات
            </a>
            @if (Model.IsActive)
            {
                <form asp-controller="AdminCrisis" asp-action="Deactivate" asp-route-id="@Model.Id" method="post" class="m-0">
                    <button type="submit" class="btn btn-danger rounded-pill px-4 py-2 fw-800">
                        <i class="fas fa-power-off me-1"></i> إيقاف تفعيل الأزمة
                    </button>
                </form>
            }
            else
            {
                <form asp-controller="AdminCrisis" asp-action="Activate" asp-route-id="@Model.Id" method="post" class="m-0">
                    <button type="submit" class="btn btn-success rounded-pill px-4 py-2 fw-800">
                        <i class="fas fa-play me-1"></i> تفعيل وضع الأزمات
                    </button>
                </form>
            }
        </div>
    </div>

    <!-- Left Column: Details & Stats -->
    <div class="col-lg-5 col-12">
        <!-- Main details -->
        <div class="dashboard-card mb-4">
            <h4 class="card-header-sm">
                <i class="fas fa-info-circle text-primary"></i> معلومات الأزمة
            </h4>
            <div class="table-responsive">
                <table class="table table-borderless align-middle m-0" style="font-size: 0.9rem;">
                    <tbody>
                        <tr>
                            <td class="text-muted fw-bold py-2" style="width: 140px;">نوع الأزمة:</td>
                            <td class="fw-800 py-2">@Model.CrisisType</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-bold py-2">وضع النظام المرتبط:</td>
                            <td class="fw-800 py-2">
                                @if (Model.SystemMode == Etmen_Domain.Enums.SystemMode.Crisis)
                                {
                                    <span class="badge-pill-custom badge-medium">
                                        <i class="fas fa-triangle-exclamation"></i> وضع طوارئ وأزمات
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-pill-custom badge-active">
                                        <i class="fas fa-hand-holding-heart"></i> وضع طبي اعتيادي
                                    </span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-bold py-2">تاريخ البدء:</td>
                            <td class="fw-800 py-2 font-monospace">@Model.StartDate.ToString("yyyy-MM-dd")</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-bold py-2">تاريخ الانتهاء المتوقع:</td>
                            <td class="fw-800 py-2 font-monospace">@(Model.EndDate?.ToString("yyyy-MM-dd") ?? "مستمر دون تحديد")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- System Stats if available -->
        <div class="dashboard-card mb-4">
            <h4 class="card-header-sm">
                <i class="fas fa-chart-pie text-primary"></i> مؤشرات تفشي الأزمة
            </h4>
            @if (stats != null)
            {
                <div class="row g-3">
                    <div class="col-6">
                        <div class="metric-small-card text-center">
                            <span class="text-muted small d-block mb-1">إجمالي الفحوصات</span>
                            <h3 class="fw-900 m-0 text-primary font-monospace">@stats.TotalAssessments</h3>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="metric-small-card text-center">
                            <span class="text-muted small d-block mb-1">متوسط درجة الخطورة</span>
                            <h3 class="fw-900 m-0 text-dark font-monospace">@stats.AverageRiskScore.ToString("F2")</h3>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="metric-small-card text-center border-danger-subtle bg-danger-subtle bg-opacity-10">
                            <span class="text-danger small d-block mb-1"><i class="fas fa-radiation"></i> حالات حرجة جداً</span>
                            <h3 class="fw-900 m-0 text-danger font-monospace">@stats.CriticalCount</h3>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="metric-small-card text-center border-warning-subtle bg-warning-subtle bg-opacity-10">
                            <span class="text-warning small d-block mb-1"><i class="fas fa-exclamation-triangle"></i> حالات خطرة</span>
                            <h3 class="fw-900 m-0 text-warning font-monospace">@stats.HighRiskCount</h3>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="metric-small-card d-flex align-items-center justify-content-between">
                            <div>
                                <span class="text-muted small d-block mb-1">البؤر الجغرافية المكتشفة</span>
                                <h4 class="fw-800 m-0 text-dark"><i class="fas fa-map-pin text-danger me-1"></i> @stats.OutbreakZonesCount بؤرة وبائية</h4>
                            </div>
                            <a href="/AdminCrisis/Heatmap?crisisId=@Model.Id" class="btn btn-outline-primary btn-sm rounded-pill">
                                <i class="fas fa-map-location-dot"></i> عرض الخريطة
                            </a>
                        </div>
                    </div>
                </div>
                <div class="text-muted small text-start mt-3">
                    <i class="fas fa-clock me-1"></i> آخر تحديث للمؤشرات: @stats.LastUpdated.ToString("yyyy-MM-dd HH:mm")
                </div>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="fas fa-circle-notch fa-spin text-primary fs-3 mb-2"></i>
                    <p class="small mb-0">المؤشرات الإحصائية غير متوفرة حالياً.</p>
                </div>
            }
        </div>
    </div>

    <!-- Right Column: Symptom weights -->
    <div class="col-lg-7 col-12">
        <div class="dashboard-card">
            <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
                <h4 class="fw-900 m-0">
                    <i class="fas fa-weight-hanging text-primary me-2"></i> أوزان الأعراض وتصنيف الفرز الذكي
                </h4>
                <button type="button" class="btn btn-primary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addSymptomModal">
                    <i class="fas fa-plus me-1"></i> إضافة عرض جديد
                </button>
            </div>

            @if (Model.SymptomWeights == null || Model.SymptomWeights.Count == 0)
            {
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-clipboard-list fs-1 text-primary mb-3"></i>
                    <h5>لا توجد أعراض معرفة لهذه الأزمة.</h5>
                    <p class="small mb-0">أضف الأعراض الشائعة للأزمة الطبية مع تحديد وزنها النسبي لتمكين نظام تقييم المخاطر.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr class="table-light">
                                <th style="font-weight: 800;">العَرَض الطبي</th>
                                <th style="font-weight: 800;">الوزن النسبي (0 - 1)</th>
                                <th style="font-weight: 800;">مستوى التصنيف</th>
                                <th style="font-weight: 800; text-align: center;">إجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var symptom in Model.SymptomWeights)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-800 text-dark">@symptom.SymptomName</div>
                                    </td>
                                    <td>
                                        <form asp-controller="AdminCrisis" asp-action="UpdateSymptom" asp-route-crisisId="@Model.Id" asp-route-symptomName="@symptom.SymptomName" method="post" class="d-flex align-items-center gap-2 m-0">
                                            <input type="hidden" name="SymptomName" value="@symptom.SymptomName" />
                                            <input type="hidden" name="IsEmergencySymptom" value="@(symptom.IsEmergencySymptom ? "true" : "false")" />
                                            <div class="input-group input-group-sm weight-input-group">
                                                <input type="number" step="0.05" min="0" max="1" name="Weight" value="@symptom.Weight.ToString("0.00")" class="form-control font-monospace text-center fw-bold rounded-start" />
                                                <button type="submit" class="btn btn-outline-primary" title="تحديث الوزن"><i class="fas fa-save"></i></button>
                                            </div>
                                        </form>
                                    </td>
                                    <td>
                                        @if (symptom.IsEmergencySymptom)
                                        {
                                            <span class="badge-pill-custom badge-emergency">
                                                <i class="fas fa-triangle-exclamation"></i> عرض طارئ وحرج
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge-pill-custom badge-medium">
                                                <i class="fas fa-circle-info"></i> عرض اعتيادي
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center">
                                            <form asp-controller="AdminCrisis" asp-action="RemoveSymptom" asp-route-crisisId="@Model.Id" asp-route-symptomName="@symptom.SymptomName" method="post" class="m-0" onsubmit="return confirm('هل أنت متأكد من حذف هذا العرض من الأزمة؟');">
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill" title="حذف العرض">
                                                    <i class="fas fa-trash-can"></i> حذف
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal to Add Symptom -->
<div class="modal fade" id="addSymptomModal" tabindex="-1" aria-labelledby="addSymptomModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 bg-light px-4 py-3" style="border-top-left-radius: 20px; border-top-right-radius: 20px;">
                <h5 class="modal-title fw-900" id="addSymptomModalLabel"><i class="fas fa-plus text-primary me-2"></i> إضافة عرض طبي جديد للأزمة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="AdminCrisis" asp-action="AddSymptom" asp-route-crisisId="@Model.Id" method="post" class="m-0">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label for="SymptomName" class="form-label fw-800 text-dark">اسم العَرَض الطبي</label>
                        <input type="text" id="SymptomName" name="SymptomName" class="form-control rounded-pill px-3" placeholder="مثال: صعوبة شديدة في التنفس، حرارة مرتفعة..." required />
                    </div>
                    <div class="mb-3">
                        <label for="Weight" class="form-label fw-800 text-dark">الوزن النسبي في الفرز (0.00 إلى 1.00)</label>
                        <input type="number" step="0.01" min="0" max="1" id="Weight" name="Weight" value="0.5" class="form-control font-monospace rounded-pill px-3" required />
                        <div class="form-text text-muted small">كلما زاد الوزن كلما ارتفع تقييم خطورة الحالة عند الفرز.</div>
                    </div>
                    <div class="form-check form-switch p-0 mt-3 d-flex align-items-center justify-content-between">
                        <label class="form-check-label fw-800 text-dark" for="IsEmergencySymptom">تصنيف كعرض طارئ وحرج (يستدعي النقل الفوري)</label>
                        <input class="form-check-input ms-3" type="checkbox" id="IsEmergencySymptom" name="IsEmergencySymptom" value="true" style="cursor: pointer; width: 45px; height: 24px;" />
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4"><i class="fas fa-save me-1"></i> حفظ العرض</button>
                </div>
            </form>
        </div>
    </div>
</div>
