@using Etmen_PL.Models.ViewModels.Doctor
@model UpdateAppointmentStatusViewModel
@{
    ViewData["Title"] = "تحديث حالة الموعد";
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="dr-card animate__animated animate__fadeInUp">
            <div class="dr-card-header">
                <h5 class="dr-card-title"><i class="fas fa-edit"></i> تحديث حالة الموعد</h5>
                <a href="/DoctorAppointments" class="btn-outline-custom btn-sm py-1 px-3" style="font-size:0.75rem;">
                    <i class="fas fa-arrow-left ms-1"></i> العودة
                </a>
            </div>

            <form asp-action="UpdateStatus" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="AppointmentId" />

                <div asp-validation-summary="ModelOnly" class="custom-alert custom-alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label">الحالة</label>
                    <select asp-for="Status" class="form-select">
                        <option value="">-- اختر الحالة --</option>
                        <option value="Confirmed">مؤكد</option>
                        <option value="InProgress">قيد التنفيذ</option>
                        <option value="Completed">مكتمل</option>
                        <option value="Cancelled">ملغي</option>
                        <option value="NoShow">لم يحضر</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger small fw-bold"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Notes" class="form-label">ملاحظات (اختياري)</label>
                    <textarea asp-for="Notes" class="form-control" rows="4" placeholder="أي ملاحظات إضافية حول الموعد..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger small fw-bold"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom flex-fill">
                        <i class="fas fa-save"></i> حفظ التحديث
                    </button>
                    <a href="/DoctorAppointments" class="btn-outline-custom flex-fill text-center">
                        إلغاء
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
