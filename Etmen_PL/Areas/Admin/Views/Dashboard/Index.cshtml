@model Etmen_PL.Areas.Admin.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "لوحة الإدارة - إطمن";
    Layout = null;
    var dash = Model.Dashboard;
    var crisis = Model.Crisis;
    var activeProviders = Model.Providers.Items.Count(p => p.IsActive);
    var inactiveProviders = Model.Providers.Items.Count(p => !p.IsActive);
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>@ViewData["Title"]</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<style>
:root{--primary:#1A6FBF;--primary-dark:#0D4C8A;--accent:#00A88F;--success:#27AE60;--danger:#E74C3C;--warning:#F39C12;--dark:#0F1923;--dark-2:#1B2A38;--text:#253342;--muted:#718093;--border:#DDE5EF;--surface:#FFFFFF;--page:#F0F4F9;}
*{box-sizing:border-box;margin:0;padding:0}body{font-family:'Tajawal',sans-serif;background:var(--page);color:var(--text);min-height:100vh;display:flex}a{text-decoration:none}.sidebar{width:270px;min-height:100vh;background:var(--dark);position:fixed;right:0;top:0;display:flex;flex-direction:column;z-index:10}.sidebar-logo{padding:28px 24px;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;gap:12px}.logo-icon{width:42px;height:42px;border-radius:10px;background:linear-gradient(135deg,var(--primary),var(--accent));display:flex;align-items:center;justify-content:center;color:#fff}.logo-text{font-size:1.25rem;font-weight:900;color:#fff}.logo-text span{color:var(--accent)}.nav-section{padding:20px 18px 8px;color:rgba(255,255,255,.38);font-size:.72rem;font-weight:800;letter-spacing:.05em}.nav-item{display:flex;align-items:center;gap:12px;color:rgba(255,255,255,.68);padding:12px 18px;margin:2px 12px;border-radius:10px;font-weight:600;transition:.18s}.nav-item:hover,.nav-item.active{background:rgba(26,111,191,.25);color:#fff}.nav-item.active{border-right:3px solid var(--primary)}.nav-item i{width:20px;text-align:center}.sidebar-footer{margin-top:auto;padding:20px;border-top:1px solid rgba(255,255,255,.08)}.logout-btn{width:100%;border:0;background:transparent;color:rgba(255,255,255,.56);display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;font-weight:700}.logout-btn:hover{background:rgba(231,76,60,.14);color:#fff}.main{margin-right:270px;flex:1;min-height:100vh}.topbar{height:74px;background:#fff;border-bottom:1px solid var(--border);padding:0 32px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:5}.topbar h1{font-size:1.1rem;font-weight:800;margin:0}.topbar p{font-size:.83rem;color:var(--muted);margin:4px 0 0}.topbar-actions{display:flex;align-items:center;gap:12px}.chip{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--border);background:#fff;border-radius:999px;padding:8px 14px;color:var(--muted);font-size:.85rem;font-weight:700}.avatar{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--primary),var(--accent));color:#fff;font-weight:900}.page{padding:30px 32px 40px}.hero{background:linear-gradient(135deg,#102033,#164E7D);color:#fff;padding:26px 28px;border-radius:8px;margin-bottom:24px;display:grid;grid-template-columns:1.4fr .8fr;gap:20px;align-items:center}.hero h2{font-size:1.55rem;font-weight:900;margin-bottom:8px}.hero p{color:rgba(255,255,255,.76);margin:0;line-height:1.8}.hero-status{display:flex;gap:12px;justify-content:flex-end;flex-wrap:wrap}.status-pill{border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.08);border-radius:8px;padding:12px 14px;min-width:150px}.status-pill strong{display:block;font-size:1.2rem}.status-pill span{font-size:.8rem;color:rgba(255,255,255,.72)}.stats-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:16px;margin-bottom:24px}.stat{background:#fff;border:1px solid var(--border);border-radius:8px;padding:20px;position:relative;overflow:hidden}.stat:before{content:"";position:absolute;top:0;right:0;width:4px;height:100%;background:var(--c,var(--primary))}.stat i{width:44px;height:44px;border-radius:8px;display:flex;align-items:center;justify-content:center;background:var(--bg,rgba(26,111,191,.1));color:var(--c,var(--primary));font-size:1.15rem;margin-bottom:14px}.stat .value{font-size:1.65rem;font-weight:900;color:var(--dark);line-height:1}.stat .label{font-size:.84rem;color:var(--muted);font-weight:700;margin-top:7px}.grid{display:grid;grid-template-columns:1.35fr .65fr;gap:22px;margin-bottom:22px}.section{background:#fff;border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-bottom:22px}.section-header{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:12px}.section-header h3{font-size:1rem;font-weight:900;margin:0;display:flex;align-items:center;gap:10px}.section-header small{color:var(--muted);font-weight:700}.section-body{padding:20px 22px}.table-wrap{overflow-x:auto}.data-table{width:100%;border-collapse:collapse;min-width:760px}.data-table th{background:#F8FAFC;color:var(--muted);font-size:.78rem;font-weight:900;text-align:right;padding:12px 14px;border-bottom:1px solid var(--border);white-space:nowrap}.data-table td{padding:13px 14px;border-bottom:1px solid rgba(0,0,0,.045);font-size:.88rem;vertical-align:middle}.data-table tr:last-child td{border-bottom:0}.person{display:flex;align-items:center;gap:10px}.mini-avatar{width:34px;height:34px;border-radius:50%;background:#E8F4FD;color:var(--primary);display:flex;align-items:center;justify-content:center;font-weight:900}.muted{color:var(--muted)}.badge-soft{display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:5px 10px;font-size:.77rem;font-weight:900}.ok{background:#E8F8F0;color:var(--success)}.off{background:#FDECEA;color:var(--danger)}.warn{background:#FFF5DF;color:#B46B00}.info{background:#E8F4FD;color:var(--primary)}.actions{display:flex;align-items:center;gap:8px;flex-wrap:wrap}.icon-btn{width:34px;height:34px;border:1px solid var(--border);border-radius:8px;background:#fff;color:var(--muted);display:inline-flex;align-items:center;justify-content:center;cursor:pointer}.icon-btn:hover{border-color:var(--primary);color:var(--primary)}.btn-main{border:0;border-radius:8px;background:var(--primary);color:#fff;font-weight:900;padding:10px 16px;display:inline-flex;align-items:center;gap:8px}.btn-main:hover{background:var(--primary-dark);color:#fff}.btn-lightx{border:1px solid var(--border);border-radius:8px;background:#fff;color:var(--text);font-weight:800;padding:9px 13px}.btn-dangerx{border:0;border-radius:8px;background:var(--danger);color:#fff;font-weight:900;padding:9px 13px}.field-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}.field-grid.three{grid-template-columns:repeat(3,1fr)}label{font-size:.78rem;color:var(--muted);font-weight:900;margin-bottom:6px}.form-control,.form-select{border-radius:8px;border-color:var(--border);font-size:.9rem}.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid rgba(0,0,0,.06);gap:12px}.toggle-row:last-child{border-bottom:0}.toggle-row strong{font-size:.9rem}.toggle-row span{font-size:.78rem;color:var(--muted)}.log-list{display:flex;flex-direction:column;gap:12px}.log-item{display:flex;gap:12px;align-items:flex-start}.log-dot{width:10px;height:10px;border-radius:50%;background:var(--primary);margin-top:7px}.log-item strong{font-size:.88rem}.log-item p{margin:2px 0 0;color:var(--muted);font-size:.8rem}.toast-wrap{position:fixed;bottom:24px;left:24px;z-index:50}.toast-msg{border-radius:8px;color:#fff;font-weight:900;padding:13px 18px;box-shadow:0 10px 28px rgba(0,0,0,.18);display:flex;gap:10px;align-items:center}.toast-success{background:var(--success)}.toast-error{background:var(--danger)}.empty{padding:28px;text-align:center;color:var(--muted)}.empty i{font-size:2rem;opacity:.45;margin-bottom:10px}.pager{display:flex;gap:8px;align-items:center;justify-content:flex-end;padding:14px 22px;border-top:1px solid var(--border)}.pager a,.pager span{border:1px solid var(--border);border-radius:8px;padding:8px 12px;color:var(--text);font-weight:800;font-size:.83rem}.pager .disabled{opacity:.45}.modal-content{border-radius:8px;border:0}.modal-header{border-bottom:1px solid var(--border)}.modal-title{font-weight:900}
@@media(max-width:1200px){.stats-grid{grid-template-columns:repeat(3,1fr)}.grid{grid-template-columns:1fr}.hero{grid-template-columns:1fr}.hero-status{justify-content:flex-start}}@@media(max-width:780px){.sidebar{position:static;width:100%;min-height:auto}.main{margin-right:0}.topbar{height:auto;padding:18px;align-items:flex-start;gap:12px}.page{padding:18px}.stats-grid{grid-template-columns:1fr}.field-grid,.field-grid.three{grid-template-columns:1fr}body{display:block}}
</style>
</head>
<body>
<aside class="sidebar">
  <div class="sidebar-logo"><div class="logo-icon"><i class="fas fa-heartbeat"></i></div><div class="logo-text">إط<span>من</span></div></div>
  <span class="nav-section">الإدارة</span>
  <a href="/Admin/Dashboard" class="nav-item active"><i class="fas fa-chart-line"></i>لوحة الإدارة</a>
  <a href="#users" class="nav-item"><i class="fas fa-users"></i>المستخدمون</a>
  <a href="#providers" class="nav-item"><i class="fas fa-hospital"></i>مقدمو الخدمة</a>
  <a href="#crisis" class="nav-item"><i class="fas fa-shield-virus"></i>إدارة الأزمة</a>
  <a href="#settings" class="nav-item"><i class="fas fa-sliders"></i>إعدادات النظام</a>
  <div class="sidebar-footer">
    <form method="post" action="/Account/Logout">@Html.AntiForgeryToken()<button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i>تسجيل الخروج</button></form>
  </div>
</aside>
<main class="main">
  <div class="topbar">
    <div><h1>لوحة الإدارة</h1><p>مركز قيادة منصة إطمن ومتابعة التشغيل الصحي</p></div>
    <div class="topbar-actions"><span class="chip"><i class="fas fa-clock"></i>@dash.LastUpdated.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt")</span><div class="avatar">أ</div></div>
  </div>
  <div class="page">
    <section class="hero">
      <div>
        <h2>إدارة ذكية للمنصة، بالعربي بالكامل</h2>
        <p>تابع المستخدمين، مقدمي الرعاية، وضع الأزمة، والتقارير التشغيلية من شاشة واحدة بنفس هوية إطمن الهادئة والواضحة.</p>
      </div>
      <div class="hero-status">
        <div class="status-pill"><strong>@(dash.IsCrisisModeActive ? "نشط" : "طبيعي")</strong><span>وضع الأزمة</span></div>
        <div class="status-pill"><strong>@(dash.ActiveCrisisName ?? "لا توجد")</strong><span>الأزمة الحالية</span></div>
      </div>
    </section>

    <section class="stats-grid">
      <div class="stat" style="--c:var(--primary);--bg:rgba(26,111,191,.1)"><i class="fas fa-users"></i><div class="value">@dash.TotalUsers</div><div class="label">إجمالي المستخدمين</div></div>
      <div class="stat" style="--c:var(--success);--bg:rgba(39,174,96,.1)"><i class="fas fa-user-doctor"></i><div class="value">@dash.ActiveDoctors</div><div class="label">أطباء نشطون</div></div>
      <div class="stat" style="--c:var(--accent);--bg:rgba(0,168,143,.1)"><i class="fas fa-bed-pulse"></i><div class="value">@dash.ActivePatients</div><div class="label">مرضى نشطون</div></div>
      <div class="stat" style="--c:var(--warning);--bg:rgba(243,156,18,.13)"><i class="fas fa-calendar-check"></i><div class="value">@dash.TotalAppointments</div><div class="label">إجمالي المواعيد</div></div>
      <div class="stat" style="--c:var(--danger);--bg:rgba(231,76,60,.1)"><i class="fas fa-truck-medical"></i><div class="value">@dash.PendingEmergencyRequests</div><div class="label">طوارئ معلقة</div></div>
    </section>

    <div class="grid">
      <section class="section" id="users">
        <div class="section-header"><h3><i class="fas fa-users" style="color:var(--primary)"></i>إدارة المستخدمين</h3><small>@Model.Users.TotalCount مستخدم</small></div>
        @if (Model.Users.Items.Any())
        {
          <form method="post" action="/Admin/Dashboard/BulkUsers">@Html.AntiForgeryToken()
            <div class="table-wrap"><table class="data-table"><thead><tr><th></th><th>المستخدم</th><th>الدور</th><th>البريد</th><th>الحالة</th><th>آخر دخول</th><th>إجراءات</th></tr></thead><tbody>
            @foreach (var user in Model.Users.Items)
            {
              <tr>
                <td><input type="checkbox" name="UserIds" value="@user.Id" /></td>
                <td><div class="person"><div class="mini-avatar">@((string.IsNullOrWhiteSpace(user.FullName) ? user.Email : user.FullName)[0])</div><div><strong>@(string.IsNullOrWhiteSpace(user.FullName) ? "بدون اسم" : user.FullName)</strong><div class="muted">من @user.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</div></div></div></td>
                <td><span class="badge-soft info">@user.Role</span></td>
                <td>@user.Email</td>
                <td><span class="badge-soft @(user.IsActive ? "ok" : "off")"><i class="fas fa-circle"></i>@(user.IsActive ? "مفعل" : "معطل")</span></td>
                <td>@(user.LastLoginAt?.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt") ?? "لا يوجد")</td>
                <td><div class="actions"><form method="post" action="/Admin/Dashboard/ToggleUserStatus">@Html.AntiForgeryToken()<input type="hidden" name="userId" value="@user.Id" /><input type="hidden" name="isActive" value="@(!user.IsActive)" /><button class="icon-btn" title="@(user.IsActive ? "تعطيل" : "تفعيل")"><i class="fas @(user.IsActive ? "fa-user-slash" : "fa-user-check")"></i></button></form></div></td>
              </tr>
            }
            </tbody></table></div>
            <div class="section-body" style="border-top:1px solid var(--border);display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap"><select name="Action" class="form-select" style="max-width:190px"><option value="activate">تفعيل المحدد</option><option value="deactivate">تعطيل المحدد</option></select><button class="btn-main"><i class="fas fa-bolt"></i>تنفيذ</button></div>
          </form>
          <div class="pager"><a class="@(Model.Users.HasPreviousPage ? "" : "disabled")" href="/Admin/Dashboard?usersPage=@(Model.UsersPage - 1)#users">السابق</a><span>@Model.Users.PageNumber / @Math.Max(Model.Users.TotalPages, 1)</span><a class="@(Model.Users.HasNextPage ? "" : "disabled")" href="/Admin/Dashboard?usersPage=@(Model.UsersPage + 1)#users">التالي</a></div>
        }
        else { <div class="empty"><i class="fas fa-users-slash"></i><p>لا توجد بيانات مستخدمين حالياً.</p></div> }
      </section>

      <aside>
        <section class="section" id="crisis">
          <div class="section-header"><h3><i class="fas fa-shield-virus" style="color:var(--danger)"></i>وضع الأزمة</h3><span class="badge-soft @(crisis.IsActive ? "off" : "ok")">@(crisis.IsActive ? "نشط" : "طبيعي")</span></div>
          <div class="section-body">
            <h4 style="font-size:1.05rem;font-weight:900;margin-bottom:8px">@crisis.CrisisName</h4>
            <p class="muted" style="line-height:1.8">نطاقات متأثرة: @crisis.ZonesCount · نمط النظام: @crisis.SystemMode · النوع: @crisis.CrisisType</p>
            @if (crisis.Id > 0)
            {
              <div class="actions" style="margin-top:16px">
                @if (!crisis.IsActive) { <form method="post" action="/Admin/Dashboard/ApproveCrisis">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@crisis.Id" /><button class="btn-main"><i class="fas fa-power-off"></i>تفعيل الأزمة</button></form> }
                else { <form method="post" action="/Admin/Dashboard/CloseCrisis">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@crisis.Id" /><input type="hidden" name="reason" value="إغلاق من لوحة الإدارة" /><button class="btn-dangerx"><i class="fas fa-circle-stop"></i>إغلاق الأزمة</button></form> }
              </div>
            }
          </div>
        </section>

        <section class="section">
          <div class="section-header"><h3><i class="fas fa-clipboard-list" style="color:var(--warning)"></i>النشاط الأخير</h3></div>
          <div class="section-body"><div class="log-list">
            @if (Model.ActivityLogs.Any()) { foreach (var log in Model.ActivityLogs) { <div class="log-item"><div class="log-dot"></div><div><strong>@log.UserName</strong><p>@log.Details · @log.Timestamp.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt")</p></div></div> } }
            else { <div class="empty"><i class="fas fa-clock-rotate-left"></i><p>لا توجد سجلات حديثة.</p></div> }
          </div></div>
        </section>
      </aside>
    </div>

    <section class="section" id="providers">
      <div class="section-header"><h3><i class="fas fa-hospital" style="color:var(--accent)"></i>مقدمو الخدمات الصحية</h3><div class="actions"><span class="badge-soft ok">@activeProviders نشط</span><span class="badge-soft off">@inactiveProviders معطل</span><button class="btn-main" data-bs-toggle="modal" data-bs-target="#addProvider"><i class="fas fa-plus"></i>إضافة مقدم خدمة</button></div></div>
      @if (Model.Providers.Items.Any())
      {
        <div class="table-wrap"><table class="data-table"><thead><tr><th>الاسم</th><th>النوع</th><th>العنوان</th><th>الهاتف</th><th>الأسرة</th><th>طوارئ</th><th>الحالة</th><th>إجراءات</th></tr></thead><tbody>
        @foreach (var provider in Model.Providers.Items)
        {
          <tr>
            <td><strong>@provider.Name</strong><div class="muted">@provider.Latitude, @provider.Longitude</div></td>
            <td>@provider.Type</td><td>@(provider.Address ?? "غير محدد")</td><td>@(provider.Phone ?? "-")</td><td>@(provider.AvailableBeds ?? 0)</td><td><span class="badge-soft @(provider.IsEmergencyCenter ? "warn" : "info")">@(provider.IsEmergencyCenter ? "نعم" : "لا")</span></td><td><span class="badge-soft @(provider.IsActive ? "ok" : "off")">@(provider.IsActive ? "نشط" : "معطل")</span></td>
            <td><div class="actions"><button class="icon-btn" title="تعديل" data-bs-toggle="modal" data-bs-target="#editProvider-@provider.Id"><i class="fas fa-pen"></i></button><form method="post" action="/Admin/Dashboard/DeleteProvider">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@provider.Id" /><button class="icon-btn" title="تعطيل"><i class="fas fa-ban"></i></button></form></div></td>
          </tr>
        }
        </tbody></table></div>
        <div class="pager"><a class="@(Model.Providers.HasPreviousPage ? "" : "disabled")" href="/Admin/Dashboard?providersPage=@(Model.ProvidersPage - 1)#providers">السابق</a><span>@Model.Providers.PageNumber / @Math.Max(Model.Providers.TotalPages, 1)</span><a class="@(Model.Providers.HasNextPage ? "" : "disabled")" href="/Admin/Dashboard?providersPage=@(Model.ProvidersPage + 1)#providers">التالي</a></div>
      }
      else { <div class="empty"><i class="fas fa-hospital-user"></i><p>لا يوجد مقدمو خدمة حتى الآن.</p></div> }
    </section>

    <div class="grid">
      <section class="section">
        <div class="section-header"><h3><i class="fas fa-file-lines" style="color:var(--primary)"></i>التقارير</h3></div>
        <div class="table-wrap"><table class="data-table" style="min-width:560px"><thead><tr><th>التقرير</th><th>الفترة</th><th>السجلات</th><th>آخر إنشاء</th></tr></thead><tbody>
        @foreach (var report in Model.Reports.Items) { <tr><td><strong>@report.ReportType</strong></td><td>@report.StartDate.ToString("dd/MM/yyyy") - @report.EndDate.ToString("dd/MM/yyyy")</td><td>@report.TotalRecords</td><td>@report.GeneratedAt.ToLocalTime().ToString("dd/MM/yyyy")</td></tr> }
        </tbody></table></div>
      </section>
      <section class="section" id="settings">
        <div class="section-header"><h3><i class="fas fa-sliders" style="color:var(--accent)"></i>إعدادات النظام</h3></div>
        <div class="section-body"><form method="post" action="/Admin/Dashboard/UpdateConfig">@Html.AntiForgeryToken()
          <div class="toggle-row"><div><strong>وضع الأزمة</strong><span>تفعيل خصائص الأزمة على مستوى النظام</span></div><input type="hidden" name="EnableCrisisMode" value="false" /><input type="checkbox" name="EnableCrisisMode" value="true" @(Model.SystemConfig.EnableCrisisMode ? "checked" : "") /></div>
          <div class="toggle-row"><div><strong>المحادثة الذكية</strong><span>مساعد طبي ذكي للمستخدمين</span></div><input type="hidden" name="EnableAIChat" value="false" /><input type="checkbox" name="EnableAIChat" value="true" @(Model.SystemConfig.EnableAIChat ? "checked" : "") /></div>
          <div class="toggle-row"><div><strong>OCR</strong><span>قراءة التحاليل والمستندات</span></div><input type="hidden" name="EnableOCR" value="false" /><input type="checkbox" name="EnableOCR" value="true" @(Model.SystemConfig.EnableOCR ? "checked" : "") /></div>
          <div class="field-grid three" style="margin-top:16px"><div><label>محاولات الدخول</label><input class="form-control" type="number" name="MaxLoginAttempts" value="@Model.SystemConfig.MaxLoginAttempts" min="1" /></div><div><label>مدة القفل بالدقائق</label><input class="form-control" type="number" name="LockoutDurationMinutes" value="@Model.SystemConfig.LockoutDurationMinutes" min="1" /></div><div><label>مهلة الجلسة</label><input class="form-control" type="number" name="SessionTimeoutMinutes" value="@Model.SystemConfig.SessionTimeoutMinutes" min="1" /></div></div>
          <input type="hidden" name="EnableFamilyLinking" value="@Model.SystemConfig.EnableFamilyLinking.ToString().ToLowerInvariant()" /><input type="hidden" name="EnableEmergencyRequests" value="@Model.SystemConfig.EnableEmergencyRequests.ToString().ToLowerInvariant()" />
          <button class="btn-main" style="margin-top:16px"><i class="fas fa-floppy-disk"></i>حفظ الإعدادات</button>
        </form></div>
      </section>
    </div>
  </div>
</main>

<div class="modal fade" id="addProvider" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content"><form method="post" action="/Admin/Dashboard/CreateProvider">@Html.AntiForgeryToken()<div class="modal-header"><h5 class="modal-title">إضافة مقدم خدمة</h5><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div class="field-grid"><div><label>الاسم</label><input class="form-control" name="Name" required /></div><div><label>النوع</label><input class="form-control" name="Type" required placeholder="مستشفى / معمل / عيادة" /></div><div><label>خط العرض</label><input class="form-control" type="number" step="0.000001" name="Latitude" required /></div><div><label>خط الطول</label><input class="form-control" type="number" step="0.000001" name="Longitude" required /></div><div><label>الهاتف</label><input class="form-control" name="Phone" /></div><div><label>الأسرة المتاحة</label><input class="form-control" type="number" min="0" name="AvailableBeds" value="0" /></div><div style="grid-column:1/-1"><label>العنوان</label><input class="form-control" name="Address" /></div><div><input type="hidden" name="IsEmergencyCenter" value="false" /><label><input type="checkbox" name="IsEmergencyCenter" value="true" /> مركز طوارئ</label></div></div></div><div class="modal-footer"><button class="btn-lightx" type="button" data-bs-dismiss="modal">إلغاء</button><button class="btn-main"><i class="fas fa-plus"></i>إضافة</button></div></form></div></div></div>

@foreach (var provider in Model.Providers.Items)
{
<div class="modal fade" id="editProvider-@provider.Id" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content"><form method="post" action="/Admin/Dashboard/UpdateProvider">@Html.AntiForgeryToken()<input type="hidden" name="Id" value="@provider.Id" /><div class="modal-header"><h5 class="modal-title">تعديل @provider.Name</h5><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div class="field-grid"><div><label>الاسم</label><input class="form-control" name="Name" value="@provider.Name" required /></div><div><label>النوع</label><input class="form-control" name="Type" value="@provider.Type" required /></div><div><label>خط العرض</label><input class="form-control" type="number" step="0.000001" name="Latitude" value="@provider.Latitude" required /></div><div><label>خط الطول</label><input class="form-control" type="number" step="0.000001" name="Longitude" value="@provider.Longitude" required /></div><div><label>الهاتف</label><input class="form-control" name="Phone" value="@provider.Phone" /></div><div><label>الأسرة المتاحة</label><input class="form-control" type="number" min="0" name="AvailableBeds" value="@(provider.AvailableBeds ?? 0)" /></div><div style="grid-column:1/-1"><label>العنوان</label><input class="form-control" name="Address" value="@provider.Address" /></div><div><input type="hidden" name="IsEmergencyCenter" value="false" /><label><input type="checkbox" name="IsEmergencyCenter" value="true" @(provider.IsEmergencyCenter ? "checked" : "") /> مركز طوارئ</label></div><div><input type="hidden" name="IsActive" value="false" /><label><input type="checkbox" name="IsActive" value="true" @(provider.IsActive ? "checked" : "") /> نشط</label></div></div></div><div class="modal-footer"><button class="btn-lightx" type="button" data-bs-dismiss="modal">إلغاء</button><button class="btn-main"><i class="fas fa-floppy-disk"></i>حفظ</button></div></form></div></div></div>
}

@if (TempData["Success"] is string successMsg) { <div class="toast-wrap"><div class="toast-msg toast-success"><i class="fas fa-check-circle"></i>@successMsg</div></div> }
@if (TempData["Error"] is string errorMsg) { <div class="toast-wrap"><div class="toast-msg toast-error"><i class="fas fa-exclamation-circle"></i>@errorMsg</div></div> }
<script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>setTimeout(()=>document.querySelectorAll('.toast-wrap').forEach(t=>t.style.display='none'),4200);</script>
</body>
</html>
