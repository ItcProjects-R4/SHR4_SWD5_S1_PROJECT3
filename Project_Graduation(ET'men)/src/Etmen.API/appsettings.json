{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=EtmenDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "SecretKey":              "REPLACE-WITH-MIN-32-CHAR-SECRET-KEY-HERE",
    "Issuer":                 "EtmenAPI",
    "Audience":               "EtmenClients",
    "ExpiryMinutes":          15,
    "RefreshTokenExpiryDays": 7
  },
  "Google": {
    "ClientId":     "YOUR-GOOGLE-CLIENT-ID.apps.googleusercontent.com",
    "ClientSecret": "YOUR-GOOGLE-CLIENT-SECRET"
  },
  "AIModel": {
    "Provider":          "MLNet",
    "ModelPath":         "wwwroot/models/risk_model_v1.zip",
    "PythonServiceUrl":  "http://localhost:8000"
  },
  "SmtpSettings": {
    "Host":     "smtp.gmail.com",
    "Port":     587,
    "User":     "noreply@earlyintervention.com",
    "Password": "YOUR-APP-PASSWORD",
    "From":     "اطمِن — Et'men <noreply@earlyintervention.com>"
  },
  "SignalR": {
    "HubPath": "/hubs/chat"
  },
  "GoogleMaps": {
    "ApiKey":           "AIzaSy-YOUR-GOOGLE-MAPS-KEY",
    "DefaultRadius":    5000,
    "MaxRadius":        25000,
    "Language":         "ar"
  },
  "NearbySearch": {
    "MaxDbResults":          20,
    "MaxGoogleResults":      20,
    "CacheDurationMinutes":  30,
    "PrioritizeRegistered":  true
  },
  "BlobStorage": {
    "Provider":              "AzureBlob",
    "ConnectionString":      "YOUR-AZURE-BLOB-CONNECTION-STRING",
    "LabResultsContainer":   "lab-results"
  },
  "Ocr": {
    "Provider":    "Tesseract",
    "ApiEndpoint": "",
    "ApiKey":      ""
  },
  "LlmChat": {
    "Provider":   "Anthropic",
    "ApiKey":     "sk-ant-YOUR-ANTHROPIC-KEY",
    "Model":      "claude-sonnet-4-6",
    "MaxTokens":  800,
    "MaxHistory": 10
  },
  "Sms": {
    "Provider":   "Vonage",
    "ApiKey":     "YOUR-VONAGE-KEY",
    "ApiSecret":  "YOUR-VONAGE-SECRET",
    "FromNumber": "+20XXXXXXXXXX",
    "Enabled":    false
  },
  "Logging": {
    "LogLevel": {
      "Default":                "Information",
      "Microsoft.AspNetCore":   "Warning"
    }
  },
  "AllowedHosts": "*"
}
